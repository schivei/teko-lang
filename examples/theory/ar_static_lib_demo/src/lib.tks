/**
 * add — the exported two-parameter integer function the theory CI's consumer.c
 * links against (`extern long long add(long long, long long)`), the same
 * LFunc/LParam/IAdd/LRet shape as `examples/regressions/native_lir_call_add`.
 *
 * @param a  the first addend
 * @param b  the second addend
 * @return   `a + b`
 */
pub fn add(a: i64, b: i64) -> i64 {
    return a + b
}
