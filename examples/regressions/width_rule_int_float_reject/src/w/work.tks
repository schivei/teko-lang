/**
 * `i32 + f64`: cross-family (int×float) arithmetic stays rejected — the W-RULE only widens
 * same-family (int-int / float-float) operands (B.38, EXPECT_COMPILE_FAIL).
 *
 * @return never — this is a compile-time rejection
 */
pub fn probe() -> i64 {
    let a: i32 = 5
    let b: f64 = 1.0
    a + b
}
