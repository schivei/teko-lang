/**
 * Attempt to bind a reference with `let` — REJECTED (owner ruling 2026-07-24): `let` protects
 * everything, deeply — nothing bound by `let` can ever be a write-through alias. A reference
 * binding is spelled `ref r: T = x`, never `let r: ref T = x` (or `let r: T = ref x`, or any other
 * `let`-plus-reference combination).
 *
 * @return  never — this body is a compile error
 */
pub fn probe() -> i64 {
    mut x: i64 = 1
    let r: ref i64 = x
    r
}
