# Regression (drop-128, 2026-07-24): a decimal integer literal whose magnitude exceeds
# u64::MAX (18446744073709551615). The literal carrier is a sign-magnitude u64 (NumInt), so
# a wider constant has no representable magnitude — a hard parse-time error naming the cap and
# pointing at the BigInt literal form (`123bi`) as the honest alternative.
# EXPECT_COMPILE_FAIL.
name = "reject_lit_over_u64"
source = "src"

[artifact]
kind = "binary"
