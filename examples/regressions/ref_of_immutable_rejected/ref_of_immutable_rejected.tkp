# NEGATIVE regression: 0.3.1 ref-adoption owner ruling (2026-07-24) — a `ref` binding's source must
# be mutable (a `var`) or another reference, never a `let`.
#
# `ref r: T = x` write-through aliases `x`'s storage; a `let`-bound `x` grants no such handle (deep
# immutability). `type_ref_binding_value` (src/checker/typer.tks) rejects it, naming the fix.
name = "ref_of_immutable_rejected"
source = "src"

[artifact]
kind = "binary"
