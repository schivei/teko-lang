/**
 * Attempt a `ref` binding whose source is an IMMUTABLE `let` local — REJECTED (owner ruling
 * 2026-07-24): a `ref` binding's source must be a mutable variable (a `var`) or another reference
 * — never a `let` (deep immutability means a `let`-bound value grants no write-through handle).
 *
 * @return  never — this body is a compile error
 */
pub fn probe() -> i64 {
    let x: i64 = 1
    ref r: i64 = x
    r
}
