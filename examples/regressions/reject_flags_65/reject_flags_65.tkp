# Regression (drop-128, 2026-07-24): a `flags` type declaring 65 members. The bit-value carrier is
# a u64 (bit 63 is the last representable), so a 65th member has no representable power-of-2 value —
# a hard checker error naming the 64-member cap, at DECLARATION time (independent of whether any
# member is ever referenced — codegen would otherwise emit an undefined `1 << 64` shift for it).
# EXPECT_COMPILE_FAIL.
name = "reject_flags_65"
source = "src"

[artifact]
kind = "binary"
