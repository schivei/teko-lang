/**
 * Attempt to read `.value` off an UN-NARROWED `ref i32 | null` local — rejected by the C5 deref
 * fence (require_narrowed): the union must be narrowed to a bare `ref i32` first.
 *
 * @return  never — this body is a compile error
 */
pub fn deref_probe() -> i32 {
    mut x: i32 = 7
    let r: ref i32 | null = &x
    r.value
}
