// Raw / verbatim and multi-line string literals are plain `str` values. Each fn returns the
// byte length of such a literal; main sums them to a deterministic exit code.

// a raw / verbatim string: the backslash is a LITERAL byte (no escape), so `a\nb` is 4 bytes
// (a, backslash, n, b) ‚Äî NOT 3.
pub fn raw_len() -> i64 { let s = @"a\nb"; s.len to i64 }                  // ‚Üí 4

// a raw string with a doubled quote `""` ‚Üí one literal `"`: `x""y` decodes to `x"y` = 3 bytes.
pub fn raw_quote_len() -> i64 { let s = @"x""y"; s.len to i64 }           // ‚Üí 3

// a multi-line string spanning two lines: `a<newline>b` = 3 bytes.
pub fn multiline_len() -> i64 {
    let s = """a
b"""
    s.len to i64                                                          // ‚Üí 3
}

// a multi-line string with a normal escape `\t` (processed) ‚Üí `a<tab>bc` = 4 bytes.
pub fn multiline_escape_len() -> i64 { let s = """a\tbc"""; s.len to i64 }   // ‚Üí 4

// ---- ORTHOGONAL modifiers: interpolation ($) composes with verbatim (@) and `"""` ----

// `@"""‚Ä¶"""` ‚Äî multi-line VERBATIM (non-interp): a lone `"` is literal, backslash literal.
// `a"b\nc` = a " b \ n c = 6 bytes.
pub fn multiline_verbatim_len() -> i64 {
    let s = @"""a"b\nc"""
    s.len to i64                                                          // ‚Üí 6
}

// `$"""x{1+1}\ny"""` ‚Äî multi-line INTERP, escapes ON: hole 1+1‚Üí`2`, `\n`‚Üí<LF>.
// `x` `2` <LF> `y` = 4 bytes.
pub fn multiline_interp_len() -> i64 {
    let s = $"""x{1 + 1}\ny"""
    s.len to i64                                                          // ‚Üí 4
}

// `$@"x{1+1}\ny"` ‚Äî single-line VERBATIM INTERP: holes ON, backslash LITERAL.
// `x` `2` `\` `n` `y` = 5 bytes.
pub fn verbatim_interp_len() -> i64 {
    let s = $@"x{1 + 1}\ny"
    s.len to i64                                                          // ‚Üí 5
}

// `$@"a""b{1}c"` ‚Äî single-line VERBATIM INTERP with the `""`‚Üí`"` collapse + a hole.
// `a` `"` `b` `1` `c` = 5 bytes.
pub fn verbatim_interp_quote_len() -> i64 {
    let s = $@"a""b{1}c"
    s.len to i64                                                          // ‚Üí 5
}

// `@$"""a"b{1}c"""` ‚Äî multi-line VERBATIM INTERP (order-free `@$`): lone `"` literal + a hole.
// `a` `"` `b` `1` `c` = 5 bytes.
pub fn multiline_verbatim_interp_len() -> i64 {
    let s = @$"""a"b{1}c"""
    s.len to i64                                                          // ‚Üí 5
}

// ---- `{{`/`}}` literal-brace DOUBLING in interpolation (depth-0 literal text only) ----

// `$"{{{abc}}}"` with abc="ab": `{{`‚Üí`{`, `{abc}`‚Üíhole `ab`, `}}`‚Üí`}` ‚áí `{ab}` = 4 bytes.
pub fn brace_double_basic_len() -> i64 {
    let abc = "ab"
    let s = $"{{{abc}}}"
    s.len to i64                                                          // ‚Üí 4
}

// `$"a{{b}}c"` ‚áí `a{b}c` = 5 bytes (no hole ‚Äî `{{`=`{`, `}}`=`}`).
pub fn brace_double_text_len() -> i64 {
    let s = $"a{{b}}c"
    s.len to i64                                                          // ‚Üí 5
}

// `$"a{{"` ‚áí `a{` = 2 bytes (string ENDS in a literal brace; close still found).
pub fn brace_double_end_len() -> i64 {
    let s = $"a{{"
    s.len to i64                                                          // ‚Üí 2
}

// `$"{{{{{abc}}}}}"` with abc="ab": `{{`+`{{`=`{{`, hole `ab`, `}}`+`}}`=`}}` ‚áí `{{ab}}` = 6 bytes.
pub fn brace_double_nested_len() -> i64 {
    let abc = "ab"
    let s = $"{{{{{abc}}}}}"
    s.len to i64                                                          // ‚Üí 6
}

// `$@"{{x}}"` ‚Äî VERBATIM interp doubling: `{x}` = 3 bytes.
pub fn brace_double_verbatim_len() -> i64 {
    let s = $@"{{x}}"
    s.len to i64                                                          // ‚Üí 3
}

// `@$"{{x}}"` ‚Äî order-free verbatim interp doubling: `{x}` = 3 bytes.
pub fn brace_double_verbatim_order_len() -> i64 {
    let s = @$"{{x}}"
    s.len to i64                                                          // ‚Üí 3
}

// user case `$"{abc}}}"` with abc="ab": hole `ab` + `}}`‚Üí`}` ‚áí `ab}` = 3 bytes
// (1 opener / 3 closers ‚Äî the closer run is odd, so it BALANCES: 1 hole-close + 1 literal `}`).
pub fn brace_double_user_close3_len() -> i64 {
    let abc = "ab"
    let s = $"{abc}}}"
    s.len to i64                                                          // ‚Üí 3
}

// user case `$"{{{abc}"` with abc="ab": `{{`‚Üí`{` + hole `ab` ‚áí `{ab` = 3 bytes
// (3 openers / 1 closer ‚Äî the opener run is odd, so it BALANCES: 1 literal `{` + 1 hole-open).
pub fn brace_double_user_open3_len() -> i64 {
    let abc = "ab"
    let s = $"{{{abc}"
    s.len to i64                                                          // ‚Üí 3
}
