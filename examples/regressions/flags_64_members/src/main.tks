let top = Perm64::M63
if !top.has(Perm64::M63) { exit(1) }
if top.has(Perm64::M0) { exit(2) }
let bottom = Perm64::M0
if bottom.has(Perm64::M63) { exit(3) }
if !bottom.has(Perm64::M0) { exit(4) }
let combo = top.add(bottom)
if !combo.has(Perm64::M63) { exit(5) }
if !combo.has(Perm64::M0) { exit(6) }
if combo.has(Perm64::M1) { exit(7) }
exit(0)
