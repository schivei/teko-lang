use casting_native_roundtrip::casting

mut total: i64 = 0

match casting::u64_to_u32(50 to u64) {
    u32 as v => if v == (50 to u32) { total = total + 50 } else { }
    error => { }
}

match casting::u64_to_u32(4294967296 to u64) {
    u32 => { }
    error => total = total + 20
}

match casting::u64_to_u8(7 to u64) {
    u8 as v => if v == (7 to u8) { total = total + 7 } else { }
    error => { }
}

exit(total)
