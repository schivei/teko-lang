/**
 * `u64 + i64`: mixed signedness at EQUAL width — no lossless common fixed-width type exists
 * (Teko has no wider backstop after drop-128), so the W-RULE (§2.2) honest-stops here,
 * demanding an explicit `to` (EXPECT_COMPILE_FAIL).
 *
 * @return never — this is a compile-time rejection
 */
pub fn probe() -> i64 {
    let a: u64 = 5 to u64
    let b: i64 = -2
    a + b
}
