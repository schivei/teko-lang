// (W10b.CLASS increment 1) a basic sealed class: a static factory + an instance method,
// exactly the sealed/no-inheritance/no-arena shape increment 1 covers.
type Dog = class {
    name: str
    age: i64

    fn make(n: str, a: i64) -> Dog {
        Dog { name = n; age = a }
    }

    fn bark(self) -> str {
        self.name
    }

    fn is_puppy(self) -> bool {
        self.age < 1
    }
}
