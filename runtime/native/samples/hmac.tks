// Phase 13 native runner — HMAC executable proof (multi-arg runtime lowering).
// hmac.<alg>(keyHex, msg) lowers to a 2-arg OP_CALL_RUNTIME: arg0 (the hex key) is staged
// via OP_SETARG, arg1 (the message) stays in $w0; emit_native_hosted marshals both into the
// ABI arg registers for teko_rt_hmac_*. Key "Jefe" = 4a656665; RFC 4231 Test Case 2.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

emit(hmac.sha256("4a656665", "what do ya want for nothing?"));
emit(hmac.sha384("4a656665", "what do ya want for nothing?"));
emit(hmac.sha512("4a656665", "what do ya want for nothing?"));
