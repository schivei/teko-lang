// Phase 13 native runner — first executable proof.
// `emit` binds to the teko_rt print primitive; the call lowers to OP_CALL_IMPORT,
// which the hosted native emitter turns into a SysV/AAPCS call into libteko_rt.a.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

emit("hello from teko native");
