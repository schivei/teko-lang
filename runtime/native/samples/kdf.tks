// Phase 13 native runner — KDF executable proof (HKDF / PBKDF2 over SHA-256).
// Hex byte inputs + integer length/iteration args -> derived key as hex.
// HKDF = RFC 5869 Test Case 1; PBKDF2 = the suite's PBKDF2-HMAC-SHA256 vector.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

// hkdf_sha256(ikm=0x0b*22, salt=00..0c, info=f0..f9, len=42)
emit(kdf.hkdf_sha256("0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b", "000102030405060708090a0b0c", "f0f1f2f3f4f5f6f7f8f9", 42));
// pbkdf2_sha256(pass="passwd", salt="salt", iters=1, len=64)
emit(kdf.pbkdf2_sha256("706173737764", "73616c74", 1, 64));
