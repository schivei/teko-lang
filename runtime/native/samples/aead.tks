// Phase 13 native runner — AEAD executable proof (4-arg runtime lowering).
// encrypt/decrypt = crypto.<cipher>_seal/_open(keyHex, nonceHex, aadHex, msgHex). seal
// returns ct‖tag (hex); open returns plaintext (hex) or "REJECT" on tag failure. AES-GCM
// vectors = NIST/McGrew-Viega Test Case 3 (empty AAD); ChaCha20-Poly1305 = RFC 8439 §2.8.2.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

// AES-GCM: seal -> ct‖tag, open round-trips -> plaintext, tampered tag -> REJECT.
emit(crypto.aes_gcm_seal("feffe9928665731c6d6a8f9467308308", "cafebabefacedbaddecaf888", "", "d9313225f88406e5a55909c5aff5269a86a7a9531534f7da2e4c303d8a318a721c3c0c95956809532fcf0e2449a6b525b16aedf5aa0de657ba637b391aafd255"));
emit(crypto.aes_gcm_open("feffe9928665731c6d6a8f9467308308", "cafebabefacedbaddecaf888", "", "42831ec2217774244b7221b784d0d49ce3aa212f2c02a4e035c17e2329aca12e21d514b25466931c7d8f6a5aac84aa051ba30b396a0aac973d58e091473f59854d5c2af327cd64a62cf35abd2ba6fab4"));
emit(crypto.aes_gcm_open("feffe9928665731c6d6a8f9467308308", "cafebabefacedbaddecaf888", "", "42831ec2217774244b7221b784d0d49ce3aa212f2c02a4e035c17e2329aca12e21d514b25466931c7d8f6a5aac84aa051ba30b396a0aac973d58e091473f59854d5c2af327cd64a62cf35abd2ba6fab5"));

// ChaCha20-Poly1305: seal -> ct‖tag, open round-trips -> plaintext.
emit(crypto.chacha20poly1305_seal("808182838485868788898a8b8c8d8e8f909192939495969798999a9b9c9d9e9f", "070000004041424344454647", "50515253c0c1c2c3c4c5c6c7", "4c616469657320616e642047656e746c656d656e206f662074686520636c617373206f66202739393a204966204920636f756c64206f6666657220796f75206f6e6c79206f6e652074697020666f7220746865206675747572652c2073756e73637265656e20776f756c642062652069742e"));
emit(crypto.chacha20poly1305_open("808182838485868788898a8b8c8d8e8f909192939495969798999a9b9c9d9e9f", "070000004041424344454647", "50515253c0c1c2c3c4c5c6c7", "d31a8d34648e60db7b86afbc53ef7ec2a4aded51296e08fea9e2b5a736ee62d63dbea45e8ca9671282fafb69da92728b1a71de0a9e060b2905d6a5b67ecd3b3692ddbd7f2d778b8c9803aee328091b58fab324e4fad675945585808b4831d7bc3ff4def08e4b7a9de576d26586cec64b61161ae10b594f09e26a7e902ecbd0600691"));
