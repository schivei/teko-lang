// Phase 13 native runner — CSPRNG executable proof.
// random.bytes(n) -> n cryptographically-secure random bytes as hex (2n chars). The output
// is non-deterministic, so run-native.sh asserts the format (length) and that two draws
// differ — not an exact KAT.
extern fn emit(s: cstr) from "teko_rt" as "teko_rt_emit";

emit(random.bytes(32));
emit(random.bytes(32));
