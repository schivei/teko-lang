// Phase 17.F.4 WASM runner — the decimal CHECKED/fail-loud proof. `decimal.parse` of a malformed
// string must NOT silently return zero: the reactor traps (__builtin_trap -> a WebAssembly
// RuntimeError the host sees), the WASM analogue of the native exit-70 abort. The `before` line is
// emitted first to prove the trap happens AT the parse. Byte-identical pre-trap stdout to native.
extern fn emit(s) from "env" as "emit";

emit("before");
let bad = decimal.parse("abc");                 // malformed -> reactor trap
emit("after " + decimal.to_string(bad));        // never reached
