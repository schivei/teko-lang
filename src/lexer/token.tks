// src/lexer/token.tks   (namespace 'teko::lexer') ‚Äî the token TYPES.

pub type TokenKind = enum {
    // --- literals & identifiers ---
    Number          // 123, 1_000
    Ident           // snake_case names
    Str             // "‚Ä¶"   ‚Äî its text is a str (B.36)
    Byte            // b'x'  ‚Äî one octet (B.36)
    Underscore      // _     ‚Äî the wildcard

    // --- keywords ---
    Fn
    Type
    Struct
    Enum
    Let
    Mut
    Const
    If
    Else
    Loop
    Break
    Continue
    Return
    Match
    When
    As
    Use
    Exp
    True            // `true`  ‚Äî bool literal (LEGISLATION ¬ß75)
    False           // `false` ‚Äî bool literal (LEGISLATION ¬ß75)
    Null            // `null`  ‚Äî the null literal (REBOOT_PLAN ¬ß202)

    // --- arithmetic & bitwise operators ---
    Plus            // +
    Minus           // -
    Star            // *
    Slash           // /
    Percent         // %
    Amp             // &
    Pipe            // |
    Caret           // ^
    Tilde           // ~
    Shl             // <<
    Shr             // >>

    // --- assignment (compound ‚Äî B.4: statement-only) ---
    Assign          // =
    PlusEq          // +=
    MinusEq         // -=
    StarEq          // *=
    SlashEq         // /=
    PercentEq       // %=
    AmpEq           // &=
    PipeEq          // |=
    CaretEq         // ^=
    ShlEq           // <<=
    ShrEq           // >>=

    // --- comparison ---
    EqEq            // ==
    Ne              // !=
    Lt              // <
    Le              // <=
    Gt              // >
    Ge              // >=

    // --- logical ---
    AndAnd          // &&
    OrOr            // ||
    Bang            // !

    // --- delimiters & punctuation ---
    LParen          // (
    RParen          // )
    LBrace          // {
    RBrace          // }
    LBracket        // [
    RBracket        // ]
    Comma           // ,
    Colon           // :
    ColonColon      // ::
    Arrow           // ->
    FatArrow        // =>
    DotDotEq        // ..=
    Newline         // a significant line break (B.26 ‚Äî statement separator)
    Doc             // /** ‚Ä¶ */ doc comment (attaches to a type/fn declaration ‚Äî optional)

    // --- word-operator (B.23) ‚Äî APPENDED LAST on purpose: `kind_byte` serializes
    //     operator kinds by their enum ordinal (E7 makes that explicit), so a new
    //     variant must not shift the existing operators. `to` is never a stored op
    //     (the cast is its own `Cast` node ‚Äî F2), so its ordinal is never serialized.
    To              // `to` ‚Äî the cast operator (x to T); preserves‚Üíok / loses‚Üíerror (E7)
    Dot             // `.` ‚Äî postfix field/method access (P2/F2); appended last, same ordinal reason
    Semicolon       // `;` ‚Äî statement/field separator (B.17); appended last, same ordinal reason ‚Äî never a stored op
    Variant         // `variant` ‚Äî variant type-body keyword (B.14); appended last, same ordinal reason ‚Äî never a stored op (P5c)

    // --- nullability (`?` is EXCLUSIVE to nullability ‚Äî LEGISLATION ¬ß75; REBOOT_PLAN
    //     ¬ß202‚Äì203). Appended last, same ordinal-stability reason as the word-ops.
    Question        // `?`  ‚Äî type suffix: `T?` is an OPTIONAL type
    QDot            // `?.` ‚Äî safe field access (null-propagating)
    QQ              // `??` ‚Äî Elvis / null-coalescing

    // --- visibility (LEGISLATION "Visibility ‚Äî pub vs exp"; B.9). `pub` appended last,
    //     same ordinal-stability reason as the word-ops/`variant` above ‚Äî never a stored
    //     op, so its ordinal is never serialized. (`exp` predates this, in the keyword block.)
    Pub             // `pub` ‚Äî public within the project (visible cross-namespace)

    // --- increment/decrement (W5-idx self-host). Appended last (ordinal stability). These
    //     are STATEMENT sugar: `i++` desugars to `i += 1`, `i--` to `i -= 1` at parse time,
    //     so they need no checker/codegen/VM node (they reuse compound assignment).
    PlusPlus        // `++` ‚Äî postfix increment (statement)
    MinusMinus      // `--` ‚Äî postfix decrement (statement)

    // --- string interpolation `$"‚Ä¶{expr}‚Ä¶"` (self-host parity). Appended last
    //     (ordinal stability ‚Äî never a stored op, so its ordinal is never serialized). The
    //     token's text is the RAW inner content between the quotes (holes + escapes still
    //     encoded); the PARSER splits it into literal pieces + hole expressions.
    Interp          // `$"‚Ä¶{expr}‚Ä¶"` ‚Äî an interpolated string (raw inner text)

    // --- membership (`in` operator ‚Äî Phase 2). Appended last (ordinal stability ‚Äî never a
    //     stored op, so its ordinal is never serialized). `<expr> in [ e0, e1, ‚Ä¶ ]` ‚Üí bool:
    //     true iff the LHS equals any element. The `[ ‚Ä¶ ]` is a SPECIAL membership-set syntax
    //     valid ONLY as the `in` RHS (there is no general array literal). Comparison-precedence;
    //     does NOT chain.
    In              // `in` ‚Äî the membership operator (x in [ ‚Ä¶ ])

    // --- attribute marker (`#name` ‚Äî D2 test gate). Appended last (ordinal stability ‚Äî never a
    //     stored op, so its ordinal is never serialized). Today only `#test` is recognized, on a
    //     function declaration (`#test fn ‚Ä¶`), marking it as a test run by `teko test` / the build
    //     gate. The lexer emits a lone `Hash`; the parser reads `Hash Ident` as the attribute.
    Hash            // `#` ‚Äî attribute marker (`#test`)

    // --- FFI (`extern` ‚Äî C7.1a). Appended last (ordinal stability ‚Äî never a stored op, so its
    //     ordinal is never serialized). `extern fn name(params) -> ret = "sym" from "lib"`
    //     declares a foreign C function (no body). `from` is NOT reserved ‚Äî it stays a normal
    //     identifier (the corpus uses `from` as a param name), matched CONTEXTUALLY by the parser
    //     in the extern position. See LEGISLATION ¬ß"FFI / `extern`".
    Extern          // `extern` ‚Äî foreign-function declarator
}

pub type Token = struct {
    kind: TokenKind
    text: str
    line: u32   // 1-based source line  (0 = unstamped) ‚Äî the lexer stamps it for file:line:col diagnostics
    col: u32    // 1-based source column (0 = unstamped) ‚Äî the lexer stamps it for file:line:col diagnostics
}
