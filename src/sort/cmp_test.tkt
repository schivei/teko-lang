/**
 * Byte-wise `cmp`: equality, ordering, and prefix handling on ASCII strings.
 */
#test fn cmp_orders_ascii() {
    teko::assert::is_true(teko::sort::cmp("a", "a") == 0)
    teko::assert::is_true(teko::sort::cmp("a", "b") == -1)
    teko::assert::is_true(teko::sort::cmp("b", "a") == 1)
    teko::assert::is_true(teko::sort::cmp("ab", "abc") == -1)
    teko::assert::is_true(teko::sort::cmp("abc", "ab") == 1)
}

/**
 * Byte-wise `cmp`: empty strings compare as the least element.
 */
#test fn cmp_handles_empty() {
    teko::assert::is_true(teko::sort::cmp("", "") == 0)
    teko::assert::is_true(teko::sort::cmp("", "a") == -1)
    teko::assert::is_true(teko::sort::cmp("a", "") == 1)
}

/**
 * Byte-wise `cmp` is UNSIGNED byte order, so uppercase `'Z'` (0x5A) precedes lowercase `'a'` (0x61).
 */
#test fn cmp_is_unsigned_byte_order() {
    teko::assert::is_true(teko::sort::cmp("Z", "a") == -1)
    teko::assert::is_true(teko::sort::cmp("a", "Z") == 1)
}

/**
 * Natural `cmp_natural`: a digit run in the middle is compared as a number, so `"file2" < "file10"`.
 */
#test fn cmp_natural_compares_mid_run_numerically() {
    teko::assert::is_true(teko::sort::cmp_natural("file2", "file10") == -1)
    teko::assert::is_true(teko::sort::cmp_natural("file10", "file2") == 1)
    teko::assert::is_true(teko::sort::cmp_natural("file2", "file2") == 0)
}

/**
 * Natural `cmp_natural`: the canonical `file2 < file10 < file100` chain, both directions.
 */
#test fn cmp_natural_orders_file_chain() {
    teko::assert::is_true(teko::sort::cmp_natural("file10", "file100") == -1)
    teko::assert::is_true(teko::sort::cmp_natural("file100", "file10") == 1)
    teko::assert::is_true(teko::sort::cmp_natural("file2", "file100") == -1)
}

/**
 * Natural `cmp_natural`: strings that are only digits compare as whole numbers.
 */
#test fn cmp_natural_pure_digits() {
    teko::assert::is_true(teko::sort::cmp_natural("2", "10") == -1)
    teko::assert::is_true(teko::sort::cmp_natural("10", "10") == 0)
    teko::assert::is_true(teko::sort::cmp_natural("100", "99") == 1)
}

/**
 * Natural `cmp_natural`: leading zeros are insignificant, so numerically-equal runs compare EQUAL
 * regardless of zero count (`"7" == "007"`, `"x1" == "x01" == "x001"`). This documented choice is
 * what lets the stable sort expose input order for distinct-but-equal keys.
 */
#test fn cmp_natural_leading_zeros_are_equal() {
    teko::assert::is_true(teko::sort::cmp_natural("7", "007") == 0)
    teko::assert::is_true(teko::sort::cmp_natural("x1", "x01") == 0)
    teko::assert::is_true(teko::sort::cmp_natural("x01", "x001") == 0)
    teko::assert::is_true(teko::sort::cmp_natural("x001", "x1") == 0)
}

/**
 * Natural `cmp_natural`: multiple digit runs are compared left to right; the first differing run
 * decides the order.
 */
#test fn cmp_natural_multiple_runs() {
    teko::assert::is_true(teko::sort::cmp_natural("x2y10", "x2y9") == 1)
    teko::assert::is_true(teko::sort::cmp_natural("x2y9", "x2y10") == -1)
    teko::assert::is_true(teko::sort::cmp_natural("x2y10", "x2y10") == 0)
}

/**
 * Natural `cmp_natural`: when one side is a digit and the other is not at the same position, the
 * two bytes are compared directly (`'1'` 0x31 < `'b'` 0x62).
 */
#test fn cmp_natural_digit_vs_non_digit() {
    teko::assert::is_true(teko::sort::cmp_natural("a1", "ab") == -1)
    teko::assert::is_true(teko::sort::cmp_natural("ab", "a1") == 1)
}

/**
 * Natural `cmp_natural`: a trailing digit run vs a shorter prefix orders the prefix first.
 */
#test fn cmp_natural_trailing_run() {
    teko::assert::is_true(teko::sort::cmp_natural("file", "file1") == -1)
    teko::assert::is_true(teko::sort::cmp_natural("file1", "file") == 1)
}

/**
 * Natural `cmp_natural`: empty strings compare as the least element, and equal exact strings tie.
 */
#test fn cmp_natural_empty_and_exact() {
    teko::assert::is_true(teko::sort::cmp_natural("", "") == 0)
    teko::assert::is_true(teko::sort::cmp_natural("", "a") == -1)
    teko::assert::is_true(teko::sort::cmp_natural("a", "") == 1)
    teko::assert::is_true(teko::sort::cmp_natural("abc123", "abc123") == 0)
}
