/**
 * Assert two `[]str` slices have equal length and equal elements in order — the whole-array check
 * `teko::assert` lacks natively.
 *
 * @param got   the slice produced by the sort under test
 * @param want  the expected slice contents
 */
fn assert_str_slice_eq(got: []str, want: []str) {
    teko::assert::is_true(got.len == want.len)
    mut i: u64 = 0
    loop {
        if i >= want.len { break }
        teko::assert::is_true(got[i] == want[i])
        i++
    }
}

/**
 * Assert two `[]i64` slices have equal length and equal elements in order.
 *
 * @param got   the slice produced by the sort under test
 * @param want  the expected slice contents
 */
fn assert_i64_slice_eq(got: []i64, want: []i64) {
    teko::assert::is_true(got.len == want.len)
    mut i: u64 = 0
    loop {
        if i >= want.len { break }
        teko::assert::is_true(got[i] == want[i])
        i++
    }
}

/**
 * `sort_str`: empty and singleton inputs are returned unchanged.
 */
#test fn sort_str_trivial_sizes() {
    let empty: []str = teko::list::empty()
    assert_str_slice_eq(teko::sort::sort_str(empty), empty)
    assert_str_slice_eq(teko::sort::sort_str(["a"]), ["a"])
}

/**
 * `sort_str`: a two-element swap, an already-sorted input, and a reversed input.
 */
#test fn sort_str_small_orderings() {
    assert_str_slice_eq(teko::sort::sort_str(["b", "a"]), ["a", "b"])
    assert_str_slice_eq(teko::sort::sort_str(["a", "b", "c"]), ["a", "b", "c"])
    assert_str_slice_eq(teko::sort::sort_str(["c", "b", "a"]), ["a", "b", "c"])
}

/**
 * `sort_str`: duplicates are kept (a sort, not a dedup) and land adjacent.
 */
#test fn sort_str_keeps_duplicates() {
    assert_str_slice_eq(teko::sort::sort_str(["c", "a", "b", "a"]), ["a", "a", "b", "c"])
}

/**
 * `sort_str_natural`: filenames with numeric suffixes sort by numeric value, not byte order.
 */
#test fn sort_str_natural_orders_filenames() {
    assert_str_slice_eq(
        teko::sort::sort_str_natural(["file10", "file2", "file1", "file100"]),
        ["file1", "file2", "file10", "file100"])
}

/**
 * STABILITY: `"x1"`, `"x01"` and `"x001"` all share one natural key (leading zeros insignificant),
 * so a STABLE sort must keep their INPUT order while placing the group after `"b"` and `"a"`. The
 * distinct strings are the distinguishable payload; an unstable sort could reorder the equal-key
 * group. Both a forward and a reversed group order are checked to pin the guarantee.
 */
#test fn sort_str_natural_is_stable_on_equal_keys() {
    assert_str_slice_eq(
        teko::sort::sort_str_natural(["x1", "b", "x01", "a", "x001"]),
        ["a", "b", "x1", "x01", "x001"])
    assert_str_slice_eq(
        teko::sort::sort_str_natural(["x001", "b", "x01", "a", "x1"]),
        ["a", "b", "x001", "x01", "x1"])
}

/**
 * `sort_i64`: empty and singleton inputs are returned unchanged.
 */
#test fn sort_i64_trivial_sizes() {
    let empty: []i64 = teko::list::empty()
    assert_i64_slice_eq(teko::sort::sort_i64(empty), empty)
    assert_i64_slice_eq(teko::sort::sort_i64([7]), [7])
}

/**
 * `sort_i64`: a two-element swap, an already-sorted input, and a reversed input.
 */
#test fn sort_i64_small_orderings() {
    assert_i64_slice_eq(teko::sort::sort_i64([2, 1]), [1, 2])
    assert_i64_slice_eq(teko::sort::sort_i64([1, 2, 3]), [1, 2, 3])
    assert_i64_slice_eq(teko::sort::sort_i64([3, 2, 1]), [1, 2, 3])
}

/**
 * `sort_i64`: negatives sort before positives, and duplicates are kept.
 */
#test fn sort_i64_negatives_and_duplicates() {
    assert_i64_slice_eq(teko::sort::sort_i64([3, -1, -5, 2, 0]), [-5, -1, 0, 2, 3])
    assert_i64_slice_eq(teko::sort::sort_i64([2, 2, 1, 1]), [1, 1, 2, 2])
}
