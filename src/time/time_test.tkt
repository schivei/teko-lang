/**
 * date_to_string honors the token WIDTH: yy is the two-digit year, single M/d are unpadded, and
 * an alternate separator (`/`) passes through.
 */
#test
fn date_to_string_token_widths() {
    let d = teko::time::date { days = 20000 to i32 }
    teko::assert::is_true(teko::time::date_to_string(d, "yy/M/d") == "24/10/4")
}

/**
 * time_to_string fills the HH/mm/ss tokens from a nanoseconds-since-midnight tick count,
 * zero-padding each two-digit field.
 */
#test
fn time_to_string_clock_pattern() {
    let noon = teko::time::time { ticks = 43200000000000 to u64 }
    teko::assert::is_true(teko::time::time_to_string(noon, "HH:mm:ss") == "12:00:00")

    let odd = teko::time::time { ticks = 3661000000000 to u64 }
    teko::assert::is_true(teko::time::time_to_string(odd, "HH:mm:ss") == "01:01:01")
}

/**
 * `date`'s carrier IS its domain: the full `i32` range round-trips through `date_from_days`
 * with no validation/clamping, at both extremes.
 */
#test
fn date_min_max_roundtrip() {
    let min_d = teko::time::date_from_days(-2147483648 to i32)
    teko::assert::is_true(min_d.days == -2147483648)

    let max_d = teko::time::date_from_days(2147483647 to i32)
    teko::assert::is_true(max_d.days == 2147483647)
}

/**
 * `time_from_ns` accepts the entire valid domain up to and including the last nanosecond of the
 * day (23:59:59.999999999 = 86_399_999_999_999 ns) without panicking, and `time_to_string`
 * renders that boundary as "23:59:59".
 */
#test
fn time_max_boundary_23_59_59_999999999() {
    let last_ns_of_day = teko::time::time_from_ns(86399999999999)
    teko::assert::is_true(last_ns_of_day.ticks == 86399999999999)
    teko::assert::is_true(teko::time::time_to_string(last_ns_of_day, "HH:mm:ss") == "23:59:59")

    let midnight = teko::time::time_from_ns(0)
    teko::assert::is_true(midnight.ticks == 0)
}

/**
 * `datetime_of` combines a `date` and a `time` field-for-field, with no reinterpretation.
 */
#test
fn datetime_of_combines_fields() {
    let d = teko::time::date_from_days(18628)
    let t = teko::time::time_from_ns(3661000000000)
    let dt = teko::time::datetime_of(d, t)
    teko::assert::is_true(dt.days == 18628)
    teko::assert::is_true(dt.ticks == 3661000000000)
}

/**
 * `timestamp_from_datetime`/`timestamp_to_datetime` round-trip exactly for a whole-second
 * datetime (sub-second precision is intentionally lossy — `timestamp` is UNIX SECONDS — so the
 * fixture only exercises second-aligned ticks), on both sides of the epoch.
 */
#test
fn timestamp_roundtrip() {
    let dt = teko::time::datetime_of(teko::time::date_from_days(18628), teko::time::time_from_ns(3661000000000))
    let ts = teko::time::timestamp_from_datetime(dt)
    teko::assert::is_true(ts == 18628 * 86400 + 3661)
    let back = teko::time::timestamp_to_datetime(ts)
    teko::assert::is_true(back.days == dt.days)
    teko::assert::is_true(back.ticks == dt.ticks)

    let pre_epoch = teko::time::datetime_of(teko::time::date_from_days(-1 to i32), teko::time::time_from_ns(0))
    let pre_ts = teko::time::timestamp_from_datetime(pre_epoch)
    teko::assert::is_true(pre_ts == 0 - 86400)
    let pre_back = teko::time::timestamp_to_datetime(pre_ts)
    teko::assert::is_true(pre_back.days == -1)
    teko::assert::is_true(pre_back.ticks == 0)
}

/**
 * `datetime_add`/`datetime_sub` normalize the ticks-of-day field back into `[0, 24h)`, carrying
 * the overflow/underflow into the date component — both crossing midnight forward and
 * backward.
 */
#test
fn datetime_add_normalizes_across_midnight() {
    let almost_midnight = teko::time::datetime_of(teko::time::date_from_days(100), teko::time::time_from_ns(82800000000000))
    let two_hours = teko::time::span_from_ns(7200000000000)
    let forward = teko::time::datetime_add(almost_midnight, two_hours)
    teko::assert::is_true(forward.days == 101)
    teko::assert::is_true(forward.ticks == 3600000000000)

    let just_after_midnight = teko::time::datetime_of(teko::time::date_from_days(100), teko::time::time_from_ns(3600000000000))
    let backward = teko::time::datetime_sub(just_after_midnight, two_hours)
    teko::assert::is_true(backward.days == 99)
    teko::assert::is_true(backward.ticks == 82800000000000)
}

/**
 * `datetime_diff` recovers the exact signed `span` between two datetimes, and is its own
 * inverse against `datetime_add`.
 */
#test
fn datetime_diff_matches_add() {
    let a = teko::time::datetime_of(teko::time::date_from_days(50), teko::time::time_from_ns(1000000000))
    let b = teko::time::datetime_of(teko::time::date_from_days(49), teko::time::time_from_ns(500000000))
    let d = teko::time::datetime_diff(a, b)
    teko::assert::is_true(d.ticks == 86400000000000 + 500000000)
    let reconstructed = teko::time::datetime_add(b, d)
    teko::assert::is_true(reconstructed.days == a.days)
    teko::assert::is_true(reconstructed.ticks == a.ticks)
}

/** `span_add`/`span_sub` are exact signed nanosecond arithmetic. */
#test
fn span_arithmetic() {
    let a = teko::time::span_from_ns(1000000000)
    let b = teko::time::span_from_ns(300000000)
    teko::assert::is_true(teko::time::span_add(a, b).ticks == 1300000000)
    teko::assert::is_true(teko::time::span_sub(a, b).ticks == 700000000)
    teko::assert::is_true(teko::time::span_sub(b, a).ticks == 0 - 700000000)
}

/** `date_add_days`/`date_diff_days` are exact signed day arithmetic. */
#test
fn date_add_and_diff_days() {
    let d = teko::time::date_from_days(1000)
    teko::assert::is_true(teko::time::date_add_days(d, 5).days == 1005)
    teko::assert::is_true(teko::time::date_add_days(d, -5 to i32).days == 995)
    teko::assert::is_true(teko::time::date_diff_days(teko::time::date_from_days(1005), d) == 5)
}

/**
 * `dto_of` attaches a fixed UTC offset to a `datetime` without altering the civil fields —
 * `dto` carries the offset alongside, never converts into it.
 */
#test
fn dto_offset_field() {
    let dt = teko::time::datetime_of(teko::time::date_from_days(18628), teko::time::time_from_ns(0))
    let plus_two = teko::time::dto_of(dt, 120)
    teko::assert::is_true(plus_two.days == 18628)
    teko::assert::is_true(plus_two.ticks == 0)
    teko::assert::is_true(plus_two.offset_minutes == 120)

    let minus_five_thirty = teko::time::dto_of(dt, -330 to i16)
    teko::assert::is_true(minus_five_thirty.offset_minutes == -330)
}
