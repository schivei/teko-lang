// src/reprobug/reprobug_test.tkt — tests for teko::reprobug.
//
// Regression test for a confirmed VM state-corruption bug: `find_function` (src/vm/vm.c
// AND src/vm/vm.tks) resolved a call's target by matching ONLY the callee's bare last
// path segment, globally, ignoring the function's declaring namespace. Two different
// namespaces declaring a same-named function (e.g. `parse_atom`) could silently cross-
// resolve a call meant for one into the other — wrong arity/signature/body — corrupting
// completely unrelated VM state (confirmed symptom: an unrelated parser test started
// panicking with "comparison on these value kinds not yet supported" once a source file
// introducing such a collision entered the corpus). See src/reprobug/reprobug.tks and
// src/reprobug/inner/inner.tks for the full writeup and the collision setup.

#test
fn own_probe_resolves_within_its_own_namespace() {
    // teko::reprobug::probe(u64) -> u64: doubles. Must NOT cross-resolve to
    // teko::reprobug::inner::probe(str) -> str.
    teko::assert::is_true(probe(21) == 42)
    teko::assert::is_true(call_own_probe(10) == 20)
}

#test
fn inner_probe_resolves_within_its_own_namespace() {
    // teko::reprobug::inner::probe(str) -> str: self-concat. Must NOT cross-resolve to
    // teko::reprobug::probe(u64) -> u64.
    teko::assert::is_true(teko::reprobug::inner::probe("ab") == "abab")
    teko::assert::is_true(teko::reprobug::inner::call_own_probe("x") == "xx")
}

#test
fn build_items_no_early_return_has_three() {
    let xs = build_items(false)
    teko::assert::is_true(xs.len == 3)
}

#test
fn build_items_early_return_has_two() {
    let xs = build_items(true)
    teko::assert::is_true(xs.len == 2)
}

#test
fn holder_field_not_corrupted_by_later_pushes() {
    let holder = build_holder_then_grow()
    teko::assert::is_true(holder.items.len == 2)
    teko::assert::is_true(tag_of_first(holder) == "a0")
}
