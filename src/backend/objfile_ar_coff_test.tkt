/**
 * colib_u32_be_at — the big-endian u32 read from `bytes` at byte index `i`
 * (the FIRST linker member's fields, byte-identical in shape to GNU's own
 * `"/"` symbol table).
 *
 * @param []byte bytes  the archive bytes
 * @param u64 i  the field's byte offset
 * @return u32  the big-endian u32 at `i`
 */
fn colib_u32_be_at(bytes: []byte, i: u64) -> u32 {
    ((bytes[i] to u32) << (24 to u32)) | ((bytes[i + (1 to u64)] to u32) << (16 to u32)) | ((bytes[i + (2 to u64)] to u32) << (8 to u32)) | (bytes[i + (3 to u64)] to u32)
}

/**
 * colib_u32_le_at — the little-endian u32 read from `bytes` at byte index `i`
 * (the SECOND linker member's fields — the little-endian counterpart of
 * `colib_u32_be_at`).
 *
 * @param []byte bytes  the archive bytes
 * @param u64 i  the field's byte offset
 * @return u32  the little-endian u32 at `i`
 */
fn colib_u32_le_at(bytes: []byte, i: u64) -> u32 {
    (bytes[i] to u32) | ((bytes[i + (1 to u64)] to u32) << (8 to u32)) | ((bytes[i + (2 to u64)] to u32) << (16 to u32)) | ((bytes[i + (3 to u64)] to u32) << (24 to u32))
}

/**
 * colib_u16_le_at — the little-endian u16 (widened to u32) read from `bytes`
 * at byte index `i` (the second linker member's per-symbol member-table
 * index field).
 *
 * @param []byte bytes  the archive bytes
 * @param u64 i  the field's byte offset
 * @return u32  the little-endian u16 at `i`, widened to u32
 */
fn colib_u16_le_at(bytes: []byte, i: u64) -> u32 {
    (bytes[i] to u32) | ((bytes[i + (1 to u64)] to u32) << (8 to u32))
}

#test
/**
 * colib_single_member_two_linker_members_layout — a one-member, one-symbol
 * `.lib` (`main.o` / symbol `main`) lays out EXACTLY: 8-byte global header +
 * 60-byte first-linker header (`Size` = "13", GNU-shaped BE payload) + 13-byte
 * first-linker payload (BE count=1, BE offset=162, `"main\0"`) + 1-byte odd
 * pad + 60-byte second-linker header (`Size` = "19") + 19-byte second-linker
 * payload (LE member-count=1, LE offset=162, LE symbol-count=1, LE16 index=1,
 * `"main\0"`) + 1-byte odd pad + the 60-byte real member header (`Name` =
 * `"main.o/"`, GNU-style slash — reused `ar_member_name_field`) + the 4-byte
 * member data — 226 bytes total, hand-verified against the PE/COFF Archive
 * Library Format spec.
 *
 * @return void
 */
fn colib_single_member_two_linker_members_layout() {
    let member = ArMember { name = "main.o"; data = [0xDE to byte, 0xAD to byte, 0xBE to byte, 0xEF to byte] }
    let obj = emit_coff_lib_archive([member], [ArSymbol { name = "main"; member = 0 to u64 }])
    teko::assert::is_true(obj.len == (226 to u64))
    teko::assert::is_true(colib_u32_be_at(obj, 68 to u64) == (1 to u32))
    teko::assert::is_true(colib_u32_be_at(obj, 72 to u64) == (162 to u32))
    teko::assert::is_true(obj[76] == (0x6D to byte))
    teko::assert::is_true(obj[80] == (0 to byte))
    teko::assert::is_true(colib_u32_le_at(obj, 142 to u64) == (1 to u32))
    teko::assert::is_true(colib_u32_le_at(obj, 146 to u64) == (162 to u32))
    teko::assert::is_true(colib_u32_le_at(obj, 150 to u64) == (1 to u32))
    teko::assert::is_true(colib_u16_le_at(obj, 154 to u64) == (1 to u32))
    teko::assert::is_true(obj[156] == (0x6D to byte))
    teko::assert::is_true(obj[160] == (0 to byte))
    teko::assert::is_true(obj[162] == (0x6D to byte))
    teko::assert::is_true(obj[168] == (0x2F to byte))
    teko::assert::is_true(obj[222] == (0xDE to byte))
    teko::assert::is_true(obj[225] == (0xEF to byte))
}

#test
/**
 * coff_lib_longnames_inline_and_extended — `coff_lib_longnames` leaves a
 * <=15-byte name INLINE (the reused `ar_member_name_field`, GNU-slash-
 * terminated) and spills a longer name (unreached by KP16's sole producer)
 * into the shared `"//"` payload as `"/<offset>"`, NUL-terminated storage
 * (cross-checked against LLVM's `ArchiveWriter.cpp` COFF longnames writer —
 * NOT GNU ar's own `"/\n"` convention).
 *
 * @return void
 */
fn coff_lib_longnames_inline_and_extended() {
    let long_name = "this_name_is_over_fifteen_bytes.o"
    let result = coff_lib_longnames(["a.o", long_name])
    teko::assert::is_true(result.name_fields[0] == ar_member_name_field("a.o"))
    teko::assert::is_true(result.name_fields[1] == ar_pad_right("/0", AR_NAME_WIDTH))
    teko::assert::is_true(result.bytes.len == long_name.len + (1 to u64))
    teko::assert::is_true(result.bytes[0] == (0x74 to byte))
    teko::assert::is_true(result.bytes[result.bytes.len - (1 to u64)] == (0 to byte))
}

#test
/**
 * coff_lib_sorted_symbols_reorders_alphabetically — the second linker
 * member's REQUIRED order: `coff_lib_sorted_symbols` reorders an
 * out-of-alphabetical-order symbol list (`zeta`, `alpha`, `mid`) into
 * (`alpha`, `mid`, `zeta`), preserving each entry's `member` index.
 *
 * @return void
 */
fn coff_lib_sorted_symbols_reorders_alphabetically() {
    let sorted = coff_lib_sorted_symbols([
        ArSymbol { name = "zeta"; member = 2 to u64 },
        ArSymbol { name = "alpha"; member = 0 to u64 },
        ArSymbol { name = "mid"; member = 1 to u64 }
    ])
    teko::assert::is_true(sorted[0].name == "alpha")
    teko::assert::is_true(sorted[1].name == "mid")
    teko::assert::is_true(sorted[2].name == "zeta")
    teko::assert::is_true(sorted[0].member == (0 to u64))
    teko::assert::is_true(sorted[2].member == (2 to u64))
}

#test
/**
 * emit_static_archive_coff_wraps_one_member — the whole-program entry point
 * wraps exactly one member and its symbol index carries only the (bare,
 * un-prefixed — Windows x64's own convention) defined global (`main`),
 * matching the GNU/Mach-O counterparts' "only defined globals" filter.
 *
 * @return void
 */
fn emit_static_archive_coff_wraps_one_member() {
    let obj = emit_static_archive_coff("prog.o", [0xAA to byte, 0xBB to byte], [
        Symbol { name = "s0"; defined = true; sect = 2 to u8; offset = 0 to u32; local = true },
        Symbol { name = "main"; defined = true; sect = 1 to u8; offset = 0 to u32; local = false },
        Symbol { name = "printf"; defined = false; sect = 0 to u8; offset = 0 to u32; local = false }
    ])
    teko::assert::is_true(obj.len == (224 to u64))
    teko::assert::is_true(colib_u32_be_at(obj, 68 to u64) == (1 to u32))
    teko::assert::is_true(colib_u32_be_at(obj, 72 to u64) == (162 to u32))
    teko::assert::is_true(obj[obj.len - (2 to u64)] == (0xAA to byte))
    teko::assert::is_true(obj[obj.len - (1 to u64)] == (0xBB to byte))
}
