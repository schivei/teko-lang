/**
 * macho_ar_u32_le_at ‚Äî the little-endian u32 read from `bytes` at byte index
 * `i` (every `__.SYMDEF SORTED` payload field is little-endian 4-byte ‚Äî the
 * classic 32-bit BSD `struct ranlib` shape, run 30065167036 ground truth,
 * NOT the 8-byte-widened `ranlib_64` an earlier iteration used).
 *
 * @param []byte bytes  the archive bytes
 * @param u64 i  the field's byte offset
 * @return u32  the little-endian u32 at `i`
 */
fn macho_ar_u32_le_at(bytes: []byte, i: u64) -> u32 {
    (bytes[i] to u32) | ((bytes[i + (1 to u64)] to u32) << (8 to u32)) | ((bytes[i + (2 to u64)] to u32) << (16 to u32)) | ((bytes[i + (3 to u64)] to u32) << (24 to u32))
}

#test
/**
 * bsd_ar_global_header_and_symdef_name ‚Äî the archive opens with the shared
 * 8-byte `"!<arch>\n"` magic, and the very next bytes are the `__.SYMDEF SORTED`
 * member's `#1/20` `Name` field (20 = `len("__.SYMDEF SORTED")` (16) + 4
 * inner-pad bytes, since `8 + 60 + 16 = 84` needs 4 more to reach the next
 * 8-byte boundary, 88) ‚Äî the run-30064264749 ground-truth name (Apple's real
 * `libtool -static`/`ar t`), never the LLVM-only `__.SYMDEF_64` this writer's
 * first iteration used. This layer of the header is unaffected by the
 * run-30065167036 payload-width fix below, so its offsets stay unchanged.
 *
 * @return void
 */
fn bsd_ar_global_header_and_symdef_name() {
    let member = ArMember { name = "main.o"; data = [0xDE to byte, 0xAD to byte, 0xBE to byte, 0xEF to byte] }
    let obj = emit_bsd_ar_archive([member], [ArSymbol { name = "_main"; member = 0 to u64 }])
    teko::assert::is_true(obj[0] == (0x21 to byte))
    teko::assert::is_true(obj[7] == (0x0A to byte))
    teko::assert::is_true(obj[8] == (0x23 to byte))
    teko::assert::is_true(obj[9] == (0x31 to byte))
    teko::assert::is_true(obj[10] == (0x2F to byte))
    teko::assert::is_true(obj[11] == (0x32 to byte))
    teko::assert::is_true(obj[12] == (0x30 to byte))
    teko::assert::is_true(obj[13] == (0x20 to byte))
    teko::assert::is_true(obj[68] == (0x5F to byte))
    teko::assert::is_true(obj[83] == (0x44 to byte))
}

#test
/**
 * bsd_ar_single_member_symdef_and_member_layout ‚Äî a one-member, one-symbol
 * BSD/Darwin archive (`main.o` / symbol `_main`) lays out EXACTLY per the
 * run-30065167036 byte-for-byte ground truth against Apple's own
 * `libtool -static` reference archive: 8-byte global header + 60-byte
 * `__.SYMDEF SORTED` header (`Name`=`"#1/20"`, `Mode`=`"100644"`,
 * `Size`=`"44"` = 20 name bytes + 24 payload bytes) + 16 raw name bytes
 * (`"__.SYMDEF SORTED"`) + 4-byte zero inner pad (84 -> 88) + 24-byte payload
 * (u32 LE ranlib-array-size=8, one `{strx=0, off=112}` `struct ranlib` entry,
 * u32 LE strtab-size=8 ‚Äî the PADDED length, `align_up(6, 8)` ‚Äî `"_main\0"`
 * plus 2 zero pad bytes) + zero outer pad (24 is already 8-aligned) + the
 * 60-byte `main.o` member header (`Name`=`"#1/12"`, `Mode`=`"644"`,
 * `Size`=`"16"` = 12 name-with-padding + 4 content) + 6 raw name bytes
 * (`"main.o"`) + 6-byte zero inner pad (172 -> 184) + 4-byte content +
 * 4-byte zero outer pad (184 -> 192) ‚Äî 192 bytes total.
 *
 * @return void
 */
fn bsd_ar_single_member_symdef_and_member_layout() {
    let member = ArMember { name = "main.o"; data = [0xDE to byte, 0xAD to byte, 0xBE to byte, 0xEF to byte] }
    let obj = emit_bsd_ar_archive([member], [ArSymbol { name = "_main"; member = 0 to u64 }])
    teko::assert::is_true(obj.len == (192 to u64))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 88 to u64) == (8 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 92 to u64) == (0 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 96 to u64) == (112 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 100 to u64) == (8 to u32))
    teko::assert::is_true(obj[104] == (0x5F to byte))
    teko::assert::is_true(obj[108] == (0x6E to byte))
    teko::assert::is_true(obj[109] == (0 to byte))
    teko::assert::is_true(obj[110] == (0 to byte))
    teko::assert::is_true(obj[112] == (0x23 to byte))
    teko::assert::is_true(obj[184] == (0xDE to byte))
    teko::assert::is_true(obj[187] == (0xEF to byte))
    teko::assert::is_true(obj[188] == (0 to byte))
    teko::assert::is_true(obj[191] == (0 to byte))
}

#test
/**
 * bsd_ar_two_members_offsets_thread_through_padding ‚Äî a two-member BSD/Darwin
 * archive (`a.o`/1 byte, `b.o`/2 bytes, two symbols): the `struct ranlib`
 * entries' `ran_off` fields point at each member's own 8-byte-aligned header
 * start (128 and 200), each member's `#1/<N>` name lands right after its
 * header, zero-padded to the next 8-byte boundary before its content, and
 * zero-padded after its content back up to a multiple of 8 ‚Äî proving the
 * sequential `bsd_layout_members` offset-threading survives non-trivial
 * per-member padding on both sides even at the new 4-byte field width
 * (run 30065167036 ground truth).
 *
 * @return void
 */
fn bsd_ar_two_members_offsets_thread_through_padding() {
    let a = ArMember { name = "a.o"; data = [0x01 to byte] }
    let b = ArMember { name = "b.o"; data = [0x02 to byte, 0x03 to byte] }
    let obj = emit_bsd_ar_archive([a, b], [ArSymbol { name = "sym_a"; member = 0 to u64 }, ArSymbol { name = "sym_b"; member = 1 to u64 }])
    teko::assert::is_true(obj.len == (272 to u64))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 88 to u64) == (16 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 92 to u64) == (0 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 96 to u64) == (128 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 100 to u64) == (6 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 104 to u64) == (200 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 108 to u64) == (16 to u32))
    teko::assert::is_true(obj[112] == (0x73 to byte))
    teko::assert::is_true(obj[123] == (0 to byte))
    teko::assert::is_true(obj[124] == (0 to byte))
    teko::assert::is_true(obj[127] == (0 to byte))
    teko::assert::is_true(obj[128] == (0x23 to byte))
    teko::assert::is_true(obj[188] == (0x61 to byte))
    teko::assert::is_true(obj[191] == (0 to byte))
    teko::assert::is_true(obj[192] == (0x01 to byte))
    teko::assert::is_true(obj[193] == (0 to byte))
    teko::assert::is_true(obj[199] == (0 to byte))
    teko::assert::is_true(obj[200] == (0x23 to byte))
    teko::assert::is_true(obj[260] == (0x62 to byte))
    teko::assert::is_true(obj[263] == (0 to byte))
    teko::assert::is_true(obj[264] == (0x02 to byte))
    teko::assert::is_true(obj[265] == (0x03 to byte))
    teko::assert::is_true(obj[266] == (0 to byte))
    teko::assert::is_true(obj[271] == (0 to byte))
}

#test
/**
 * bsd_ar_two_symbols_ranlib_entries_are_sorted_alphabetically ‚Äî the same
 * two-member archive as above, but with the exported symbols handed in
 * REVERSE-alphabetical order (`sym_b` before `sym_a`): the `SORTED` promise
 * in `__.SYMDEF SORTED`'s own name (run 30064264749 ground truth) means
 * `emit_bsd_ar_archive` reorders the `struct ranlib` entries alphabetically
 * (`sym_a` first) regardless of the CALLER's order ‚Äî the first entry's
 * `ran_off` must point at member 0 (`a.o`, offset 128, `sym_a`'s real
 * member), not member 1.
 *
 * @return void
 */
fn bsd_ar_two_symbols_ranlib_entries_are_sorted_alphabetically() {
    let a = ArMember { name = "a.o"; data = [0x01 to byte] }
    let b = ArMember { name = "b.o"; data = [0x02 to byte, 0x03 to byte] }
    let obj = emit_bsd_ar_archive([a, b], [ArSymbol { name = "sym_b"; member = 1 to u64 }, ArSymbol { name = "sym_a"; member = 0 to u64 }])
    teko::assert::is_true(macho_ar_u32_le_at(obj, 96 to u64) == (128 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 104 to u64) == (200 to u32))
    teko::assert::is_true(obj[112] == (0x73 to byte))
}

#test
/**
 * bsd_name_layout_always_extended_never_inline ‚Äî EVERY BSD/Darwin member name
 * ‚Äî even a short one that would fit GNU's inline `Name` field ‚Äî uses the
 * `#1/<N>` extended form (matching LLVM's `printBSDMemberHeader`, and
 * confirmed by run 30065167036: this mechanism was independently re-verified
 * byte-identical to Apple's own reference archive): `bsd_name_layout("main.o",
 * 120)` yields the `"#1/12"` field (`main.o`.len=6 + inner_pad=6, since
 * `120+60+6=186` is 6 short of the next 8-byte boundary, 192), never
 * `"main.o/"`-style GNU inline.
 *
 * @return void
 */
fn bsd_name_layout_always_extended_never_inline() {
    let layout = bsd_name_layout("main.o", 120 to u32)
    teko::assert::is_true(layout.name_field == ar_pad_right("#1/12", AR_NAME_WIDTH))
    teko::assert::is_true(layout.raw_name.len == (6 to u64))
    teko::assert::is_true(layout.inner_pad == (6 to u32))
    teko::assert::is_true(layout.name_with_padding == (12 to u32))
}

#test
/**
 * bsd_name_layout_of_the_real_symdef_name ‚Äî `bsd_name_layout(BSD_SYMDEF_NAME,
 * 8)` (the archive's fixed symdef header start) resolves the run-30064264749
 * ground-truth name `"__.SYMDEF SORTED"` (16 bytes) to `#1/20` (16 raw bytes
 * + 4 inner-pad bytes, since `8+60+16=84` needs 4 more to reach 88) ‚Äî
 * pinning the exact constant this writer emits against the empirically
 * confirmed name, not a re-derivation of `bsd_name_layout`'s own formula.
 *
 * @return void
 */
fn bsd_name_layout_of_the_real_symdef_name() {
    let layout = bsd_name_layout(BSD_SYMDEF_NAME, 8 to u32)
    teko::assert::is_true(BSD_SYMDEF_NAME == "__.SYMDEF SORTED")
    teko::assert::is_true(layout.raw_name.len == (16 to u64))
    teko::assert::is_true(layout.inner_pad == (4 to u32))
    teko::assert::is_true(layout.name_with_padding == (20 to u32))
    teko::assert::is_true(layout.name_field == ar_pad_right("#1/20", AR_NAME_WIDTH))
}

#test
/**
 * macho_ar_symbols_prefixes_underscore_and_excludes_non_globals ‚Äî the archive
 * symbol index built from a neutral `Symbol` list carries ONLY the defined,
 * non-local entry (`main` ‚Üí `_main`), matching `objfile_macho.tks::build_strtab`'s
 * `_`-prefix convention and excluding the file-local rodata datum and the
 * undefined extern (mirrors `objfile_ar.tks::global_symbol_names`'s filter).
 *
 * @return void
 */
fn macho_ar_symbols_prefixes_underscore_and_excludes_non_globals() {
    let syms = macho_ar_symbols([
        Symbol { name = "s0"; defined = true; sect = 2 to u8; offset = 0 to u32; local = true },
        Symbol { name = "main"; defined = true; sect = 1 to u8; offset = 0 to u32; local = false },
        Symbol { name = "printf"; defined = false; sect = 0 to u8; offset = 0 to u32; local = false }
    ])
    teko::assert::is_true(syms.len == (1 to u64))
    teko::assert::is_true(syms[0].name == "_main")
    teko::assert::is_true(syms[0].member == (0 to u64))
}

#test
/**
 * emit_static_archive_macho_wraps_one_member ‚Äî the whole-program entry point
 * wraps exactly one member and its symbol index carries only the `_`-prefixed
 * defined global (`_main`), matching the GNU `emit_static_archive`'s
 * `ar_static_archive_indexes_only_defined_globals` counterpart. `prog.o` is
 * the same 6-byte name length as `main.o` (identical `#1/12` layout), so the
 * symdef span and the member's header start (112) match the single-member
 * test exactly; the CONTENT IS NOT the archive's last bytes ‚Äî its 2-byte
 * length needs 6 zero-byte outer-padding bytes to reach the next 8-byte
 * boundary, so `obj[184..186)` (not `obj[obj.len-2..]`) is the content.
 *
 * @return void
 */
fn emit_static_archive_macho_wraps_one_member() {
    let obj = emit_static_archive_macho("prog.o", [0xAA to byte, 0xBB to byte], [
        Symbol { name = "s0"; defined = true; sect = 2 to u8; offset = 0 to u32; local = true },
        Symbol { name = "main"; defined = true; sect = 1 to u8; offset = 0 to u32; local = false },
        Symbol { name = "printf"; defined = false; sect = 0 to u8; offset = 0 to u32; local = false }
    ])
    teko::assert::is_true(obj.len == (192 to u64))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 88 to u64) == (8 to u32))
    teko::assert::is_true(macho_ar_u32_le_at(obj, 96 to u64) == (112 to u32))
    teko::assert::is_true(obj[184] == (0xAA to byte))
    teko::assert::is_true(obj[185] == (0xBB to byte))
    teko::assert::is_true(obj[186] == (0 to byte))
    teko::assert::is_true(obj[191] == (0 to byte))
}
