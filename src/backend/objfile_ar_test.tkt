/**
 * ar_u32_be_at — the big-endian u32 read from `bytes` at byte index `i` (the
 * GNU archive symbol-table field reader — the ONE big-endian structure in the
 * own-backend's object-file goldens, everything else little-endian).
 *
 * @param []byte bytes  the archive bytes
 * @param u64 i  the field's byte offset
 * @return u32  the big-endian u32 at `i`
 */
fn ar_u32_be_at(bytes: []byte, i: u64) -> u32 {
    ((bytes[i] to u32) << (24 to u32)) | ((bytes[i + (1 to u64)] to u32) << (16 to u32)) | ((bytes[i + (2 to u64)] to u32) << (8 to u32)) | (bytes[i + (3 to u64)] to u32)
}

#test
/**
 * ar_archive_global_header_and_symtab_name — the archive opens with the 8-byte
 * `"!<arch>\n"` magic, and the very next byte is the GNU symbol-table member's
 * `Name` field — a lone `/` (never `/`-terminated like a real member name).
 *
 * @return void
 */
fn ar_archive_global_header_and_symtab_name() {
    let member = ArMember { name = "main.o"; data = [0xDE to byte, 0xAD to byte, 0xBE to byte, 0xEF to byte] }
    let obj = emit_ar_archive([member], [ArSymbol { name = "main"; member = 0 to u64 }])
    teko::assert::is_true(obj[0] == (0x21 to byte))
    teko::assert::is_true(obj[1] == (0x3C to byte))
    teko::assert::is_true(obj[6] == (0x3E to byte))
    teko::assert::is_true(obj[7] == (0x0A to byte))
    teko::assert::is_true(obj[8] == (0x2F to byte))
    teko::assert::is_true(obj[9] == (0x20 to byte))
}

#test
/**
 * ar_single_member_symtab_and_member_layout — a one-member, one-symbol archive
 * (`main.o` / symbol `main`) lays out EXACTLY: 8-byte global header + 60-byte
 * symtab header + 13-byte symtab data (count=1, one big-endian offset, the
 * NUL-terminated name) + one `\n` even-alignment pad (13 is odd) + the 60-byte
 * member header (name field `"main.o/"` space-padded, mode `"100644"`, size
 * `"4"`) + the 4-byte member data — 146 bytes total, hand-verified against the
 * `ar_hdr` spec field-by-field.
 *
 * @return void
 */
fn ar_single_member_symtab_and_member_layout() {
    let member = ArMember { name = "main.o"; data = [0xDE to byte, 0xAD to byte, 0xBE to byte, 0xEF to byte] }
    let obj = emit_ar_archive([member], [ArSymbol { name = "main"; member = 0 to u64 }])
    teko::assert::is_true(obj.len == (146 to u64))
    teko::assert::is_true(ar_u32_be_at(obj, 68 to u64) == (1 to u32))
    teko::assert::is_true(ar_u32_be_at(obj, 72 to u64) == (82 to u32))
    teko::assert::is_true(obj[76] == (0x6D to byte))
    teko::assert::is_true(obj[80] == (0 to byte))
    teko::assert::is_true(obj[82] == (0x6D to byte))
    teko::assert::is_true(obj[88] == (0x2F to byte))
    teko::assert::is_true(obj[122] == (0x31 to byte))
    teko::assert::is_true(obj[123] == (0x30 to byte))
    teko::assert::is_true(obj[130] == (0x34 to byte))
    teko::assert::is_true(obj[131] == (0x20 to byte))
    teko::assert::is_true(obj[140] == (0x60 to byte))
    teko::assert::is_true(obj[141] == (0x0A to byte))
    teko::assert::is_true(obj[142] == (0xDE to byte))
    teko::assert::is_true(obj[145] == (0xEF to byte))
}

#test
/**
 * ar_two_members_offsets_survive_odd_pad — a two-member archive whose FIRST
 * member's data is an ODD 1 byte (forcing a single `\n` pad byte before the
 * second member's header): the symbol table's two offsets point at each
 * member's own header start (92 and 154 — the pad byte correctly shifts the
 * second member's header past the first member's data+pad), and each member's
 * data lands exactly where its header's `Size` field says.
 *
 * @return void
 */
fn ar_two_members_offsets_survive_odd_pad() {
    let a = ArMember { name = "a.o"; data = [0x01 to byte] }
    let b = ArMember { name = "b.o"; data = [0x02 to byte, 0x03 to byte] }
    let obj = emit_ar_archive([a, b], [ArSymbol { name = "sym_a"; member = 0 to u64 }, ArSymbol { name = "sym_b"; member = 1 to u64 }])
    teko::assert::is_true(obj.len == (216 to u64))
    teko::assert::is_true(ar_u32_be_at(obj, 68 to u64) == (2 to u32))
    teko::assert::is_true(ar_u32_be_at(obj, 72 to u64) == (92 to u32))
    teko::assert::is_true(ar_u32_be_at(obj, 76 to u64) == (154 to u32))
    teko::assert::is_true(obj[92] == (0x61 to byte))
    teko::assert::is_true(obj[95] == (0x2F to byte))
    teko::assert::is_true(obj[152] == (0x01 to byte))
    teko::assert::is_true(obj[153] == (0x0A to byte))
    teko::assert::is_true(obj[154] == (0x62 to byte))
    teko::assert::is_true(obj[214] == (0x02 to byte))
    teko::assert::is_true(obj[215] == (0x03 to byte))
}

/**
 * ar_mixed_symbol_module — a neutral `Symbol` list with one file-local rodata
 * datum (`s0`), one defined global function (`main`), and one undefined extern
 * (`printf`) — the shape `emit_static_archive`'s caller (`emit_native`'s
 * `EncodedModuleX86`/`EncodedModuleRiscv`) always hands it.
 *
 * @return []Symbol  the three-symbol fixture list
 */
fn ar_mixed_symbol_module() -> []Symbol {
    [
        Symbol { name = "s0"; defined = true; sect = 2 to u8; offset = 0 to u32; local = true },
        Symbol { name = "main"; defined = true; sect = 1 to u8; offset = 0 to u32; local = false },
        Symbol { name = "printf"; defined = false; sect = 0 to u8; offset = 0 to u32; local = false }
    ]
}

#test
/**
 * ar_static_archive_indexes_only_defined_globals — `emit_static_archive` indexes
 * ONLY the defined, non-local symbol (`main`) — the file-local rodata datum and
 * the undefined extern are both excluded from the GNU symbol table, since
 * neither is a linkable entry point this member DEFINES for another object to
 * pull in.
 *
 * @return void
 */
fn ar_static_archive_indexes_only_defined_globals() {
    let obj = emit_static_archive("prog.o", [0xAA to byte, 0xBB to byte], ar_mixed_symbol_module())
    teko::assert::is_true(obj.len == (144 to u64))
    teko::assert::is_true(ar_u32_be_at(obj, 68 to u64) == (1 to u32))
    teko::assert::is_true(ar_u32_be_at(obj, 72 to u64) == (82 to u32))
    teko::assert::is_true(obj[76] == (0x6D to byte))
    teko::assert::is_true(obj[82] == (0x70 to byte))
    teko::assert::is_true(obj[88] == (0x2F to byte))
    teko::assert::is_true(obj[142] == (0xAA to byte))
    teko::assert::is_true(obj[143] == (0xBB to byte))
}
