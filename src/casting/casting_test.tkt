use teko::math

/**
 * Boundary tests for `teko::casting` (D5 refinement, C6, `cast-width-hygiene-0.3.1.md` §10.3).
 * Pure Teko, VM-runnable (no extern) — every case gates both engines through the compiler's own
 * `teko test .` VM run; the cross-engine (VM-vs-native) proof lives in the
 * `examples/regressions/casting_*` fixtures, which build AND run through both. Per converter:
 * an in-range call returns the value (never an error); an out-of-range call returns an `error`
 * (never a panic) — the errors-as-values sibling of the bare `to` cast, which still panics.
 */

/**
 * True iff a `u32 | error` carries the error arm.
 */
fn cst_is_err_u32(r: u32 | error) -> bool {
    match r { u32 => false; error => true }
}

/**
 * True iff a `u8 | error` carries the error arm.
 */
fn cst_is_err_u8(r: u8 | error) -> bool {
    match r { u8 => false; error => true }
}

/**
 * True iff a `u16 | error` carries the error arm.
 */
fn cst_is_err_u16(r: u16 | error) -> bool {
    match r { u16 => false; error => true }
}

/**
 * True iff an `i32 | error` carries the error arm.
 */
fn cst_is_err_i32(r: i32 | error) -> bool {
    match r { i32 => false; error => true }
}

/**
 * `u64_to_u32` at the boundary: in-range passes through unchanged; `u32::MAX + 1` errors.
 */
#test
fn u64_to_u32_boundary() {
    match u64_to_u32(300 to u64) {
        u32 as v => teko::assert::is_true(v == (300 to u32))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_u32(u64_to_u32(4294967296 to u64)))
    match u64_to_u32(4294967295 to u64) {
        u32 as v => teko::assert::is_true(v == math::U32_MAX)
        error => teko::assert::is_true(false)
    }
}

/**
 * `i64_to_u32` at both boundaries: negative errors; above `u32::MAX` errors; in-range passes.
 */
#test
fn i64_to_u32_boundary() {
    match i64_to_u32(300 to i64) {
        u32 as v => teko::assert::is_true(v == (300 to u32))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_u32(i64_to_u32(-1 to i64)))
    teko::assert::is_true(cst_is_err_u32(i64_to_u32(4294967296 to i64)))
}

/**
 * `u64_to_u8` and `u32_to_u8` at the `u8::MAX` boundary.
 */
#test
fn u8_narrow_boundary() {
    match u64_to_u8(200 to u64) {
        u8 as v => teko::assert::is_true(v == (200 to u8))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_u8(u64_to_u8(256 to u64)))
    match u32_to_u8(200 to u32) {
        u8 as v => teko::assert::is_true(v == (200 to u8))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_u8(u32_to_u8(256 to u32)))
}

/**
 * `u64_to_u16` and `u32_to_u16` at the `u16::MAX` boundary.
 */
#test
fn u16_narrow_boundary() {
    match u64_to_u16(40000 to u64) {
        u16 as v => teko::assert::is_true(v == (40000 to u16))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_u16(u64_to_u16(70000 to u64)))
    match u32_to_u16(40000 to u32) {
        u16 as v => teko::assert::is_true(v == (40000 to u16))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_u16(u32_to_u16(70000 to u32)))
}

/**
 * `i64_to_i32` at both boundaries: below `i32::MIN` errors; above `i32::MAX` errors; a negative
 * AND a positive in-range value both pass.
 */
#test
fn i64_to_i32_boundary() {
    match i64_to_i32(-100 to i64) {
        i32 as v => teko::assert::is_true(v == (-100 to i32))
        error => teko::assert::is_true(false)
    }
    match i64_to_i32(100 to i64) {
        i32 as v => teko::assert::is_true(v == (100 to i32))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_i32(i64_to_i32(2147483648 to i64)))
    teko::assert::is_true(cst_is_err_i32(i64_to_i32(-2147483649 to i64)))
}

/**
 * `u32_to_i32` at the `i32::MAX` boundary (its only overflow direction — `u32` has no negatives).
 */
#test
fn u32_to_i32_boundary() {
    match u32_to_i32(100 to u32) {
        i32 as v => teko::assert::is_true(v == (100 to i32))
        error => teko::assert::is_true(false)
    }
    teko::assert::is_true(cst_is_err_i32(u32_to_i32(2147483648 to u32)))
}

/**
 * `casting::u64_to_u32`'s success arm agrees with the bare `to` cast on the same in-range
 * value — the checked converter's happy path is not a DIFFERENT conversion, just a checked one.
 */
#test
fn u64_to_u32_matches_bare_to_on_success() {
    let v: u64 = 12345 to u64
    match u64_to_u32(v) {
        u32 as checked_result => teko::assert::is_true(checked_result == (v to u32))
        error => teko::assert::is_true(false)
    }
}
