// src/emit/tkb_test.tkt — tests for the .tkb codec (S1a/S1b). #test functions (no main).
// Current Teko: typed nodes are module-qualified (`checker::`) and carry all fields (line/col).

use teko::checker
use teko::parser
use teko::lexer

fn i64ty() -> checker::Type { checker::Prim { kind = checker::PrimKind::I64 } }
// a one-segment NamedType type-annotation (e.g. `i64`).
fn nt(name: str) -> parser::TypeExpr { parser::NamedType { path = parser::Path { segments = teko::list::push(teko::list::empty(), parser::Segment { name = name }) }; args = teko::list::empty() } }
fn tnum(v: i64) -> checker::TExpr { checker::TExpr { kind = checker::TNumber { is_float = false; value = parser::numint_of_i64(v); fval = 0.0 }; type = i64ty(); line = 0; col = 0 } }
// drop the last byte of a `[]byte` (str's `slice` is text-only) — shared by header_test (same ns).
fn drop_last(b: []byte) -> []byte {
    mut out: []byte = teko::list::empty()
    mut i: u64 = 0
    loop { if i + 1 >= b.len { break }; out = teko::list::push(out, b[i]); i = i + 1 }
    out
}

/** ty_prim — an `i64` Prim, the leaf the descent tests wrap and re-read. */
fn ty_prim() -> checker::Type { checker::Prim { kind = checker::PrimKind::I64 } }
/** match_prim_arm — "prim" when `ty` is DIRECTLY a Prim, else "other". A bare outer-case arm over a
    `checker::Type` value: matches on the value's OWN case tag, no transparent wrapper-descent. Both
    engines agree on this nominal-direct outcome (native tag-match == the VM's own-case pat_match);
    the old form asserted the VM's runtime single-field-wrapper descent, which native — matching on
    the static union tag — cannot replicate, so the native gate (#265) surfaced it as a divergence. */
fn match_prim_arm(ty: checker::Type) -> str {
    match ty { checker::Prim => "prim"; _ => "other" }
}

#test
fn descent_multifield_sibling_no_descend() {
    let f: checker::Type = checker::Func { params = teko::list::empty(); ret = ty_prim(); variadic = false; param_names = teko::list::empty(); n_required = 0; defaults = teko::list::empty() }
    teko::assert::is_true(match_prim_arm(f) == "other")
}

/**
 * tnum_roundtrip — `write_texpr` then `read_texpr` reconstructs the exact same `NumInt` for `v`
 * (drop-128, 2026-07-24): a `TNumber`'s sign-magnitude carrier round-trips through the frozen
 * `hi:lo` u64-pair wire encoding (`numint_hi`/`numint_lo` on write, `numint_of_hilo` on read).
 *
 * @param v  the i64 value to round-trip
 * @return   true iff the decoded value equals `v`
 */
fn tnum_roundtrip(v: i64) -> bool {
    let bytes = write_texpr(teko::list::empty(), st_empty(), tnum(v))
    let decoded = match read_texpr(Reader { data = bytes; pos = 0 }, teko::list::empty()) { RTExpr as x => x; error => return false }
    let n = match decoded.value.kind { checker::TNumber as nn => nn; _ => return false }
    parser::numint_to_i64(n.value) == v
}

/**
 * tnb_number_roundtrip — the `.tkb` `TNumber` codec survives every sign, including `i64::MIN`
 * (drop-128, 2026-07-24 — the SEED's pre-drop `(value >> 64) to u64` wire write panicked with
 * "impossible conversion" on ANY negative literal, since a negative source failed that checked
 * cast; `numint_hi`/`numint_lo`'s pure u64 arithmetic has no such barrier, #299).
 */
#test
fn tnb_number_roundtrip() {
    teko::assert::is_true(tnum_roundtrip(0))
    teko::assert::is_true(tnum_roundtrip(1))
    teko::assert::is_true(tnum_roundtrip(42))
    teko::assert::is_true(tnum_roundtrip(-1))
    teko::assert::is_true(tnum_roundtrip(-42))
    teko::assert::is_true(tnum_roundtrip(9223372036854775807))
    teko::assert::is_true(tnum_roundtrip(-9223372036854775807 - 1))
}

/** (#165 C7) whether two byte buffers are element-for-element equal (lengths + every byte). */
fn bytes_equal(a: []byte, b: []byte) -> bool {
    if a.len != b.len { return false }
    mut i: u64 = 0
    loop {
        if i >= a.len { break }
        if a[i] != b[i] { return false }
        i++
    }
    true
}
