// --- expressions ---

use teko::lexer

/**
 * NumInt ‚Äî the resolved integer-literal carrier, sign + 64-bit magnitude (drop-128,
 * 2026-07-24). Holds any value in the language's integer range `[i64::MIN, u64::MAX]`:
 * `neg=false` covers `0..=u64::MAX`, `neg=true` covers `i64::MIN..=-1`. Replaces the old
 * `i128` carrier, whose only reason to exist was to hold a high-bit u64 losslessly ‚Äî a
 * u64 with its high bit set needs 65 signed bits, not 128.
 *
 * @field neg  true iff the value is strictly negative (only ever set for a signed target)
 * @field mag  the magnitude: the value itself when `neg=false`, else its absolute value.
 *             `i64::MIN` is representable as `{ neg = true; mag = 0x8000000000000000 }`
 *             (`|i64::MIN|` = 2^63 fits u64)
 * @since 0.3.1 (drop-128-family)
 */
pub type NumInt = struct { neg: bool; mag: u64 }

/**
 * numint_of_u64 ‚Äî a non-negative `NumInt` carrying the magnitude `m` (`neg=false`). The
 * constructor every non-negated integer literal / synthesized constant value uses.
 *
 * @param m  the non-negative magnitude
 * @return   `{ neg = false; mag = m }`
 * @since 0.3.1 (drop-128-family)
 */
pub fn numint_of_u64(m: u64) -> NumInt { NumInt { neg = false; mag = m } }

/**
 * numint_of_i64 ‚Äî the `NumInt` a plain signed `i64` value denotes (sign-splits it). Safe at
 * the `i64::MIN` boundary: `-(v+1)` never overflows (`v+1` stays in range even at `i64::MIN`,
 * and negating it lands at worst on `i64::MAX`), and `+1` recovers the true magnitude ‚Äî the
 * classic MIN-safe negation, avoiding the CHECKED `i64 -> u64` cast (M.1) a direct negation
 * would need.
 *
 * @param v  the signed value to convert
 * @return   `v` as a sign-magnitude `NumInt`
 * @since 0.3.1 (drop-128-family)
 */
pub fn numint_of_i64(v: i64) -> NumInt {
    if v >= 0 { return numint_of_u64(v to u64) }
    NumInt { neg = true; mag = ((0 - (v + 1)) to u64) + 1 }
}

/**
 * numint_negate ‚Äî the arithmetic negation of `v` (unary `-`). Zero stays zero (canonical
 * non-negative); every other magnitude flips its sign flag, magnitude unchanged (sign +
 * magnitude negation never touches the magnitude bits, unlike two's-complement negation).
 *
 * @param v  the value to negate
 * @return   `-v`
 * @since 0.3.1 (drop-128-family)
 */
pub fn numint_negate(v: NumInt) -> NumInt {
    if v.mag == 0 { v } else { NumInt { neg = !v.neg; mag = v.mag } }
}

/**
 * numint_is_zero ‚Äî is `v` the value zero? (`neg` is ignored ‚Äî a canonical `NumInt` never
 * carries `neg=true` at magnitude 0, but a caller-built one might; this checks the value,
 * not the representation.)
 *
 * @param v  the value to test
 * @return   true iff `v` denotes zero
 * @since 0.3.1 (drop-128-family)
 */
pub fn numint_is_zero(v: NumInt) -> bool { v.mag == 0 }

/**
 * numint_to_i64 ‚Äî `v`'s raw 64-bit two's-complement bit pattern, reinterpreted as `i64` (the
 * SAME register value the native backend would hold). Teko's `u64 -> i64` `to` cast is
 * CHECKED (a same-width cross-signedness cast, M.1) and panics on a magnitude past
 * `i64::MAX` ‚Äî exactly the high-magnitude values this function must reinterpret, never
 * reject ‚Äî so it never casts the full magnitude directly. Instead it splits `mag` into two
 * 32-bit halves (each provably `<= u32::MAX`, so `to i64` on either half is a plain widening
 * cast, always safe) and reconstructs the 64-bit pattern with ordinary WRAPPING `i64`
 * arithmetic (`+`/`*`, never checked ‚Äî the native backend emits them as bare machine ops),
 * then negates in `i64` when `v.neg` (wrapping negation is its own correct two's-complement
 * inverse even at the `i64::MIN` boundary ‚Äî no corner case needed). Every carrier that needs
 * a plain machine-register view of a literal (LIR constants, the interpreters, const-
 * aggregate serialization) goes through this one conversion.
 *
 * @param v  the value to reinterpret
 * @return   `v`'s value as a raw i64 register bit pattern
 * @since 0.3.1 (drop-128-family)
 */
pub fn numint_to_i64(v: NumInt) -> i64 {
    let hi = (v.mag >> 32) to i64
    let lo = (v.mag & 0xFFFFFFFF) to i64
    let bits = (hi * 4294967296) + lo
    if v.neg { 0 - bits } else { bits }
}

/**
 * A literal number leaf (N1 ‚Äî TEKO_CORRECTION_PLAN ¬ß5). Carries the RAW value; the resolved
 * type (set by the typer) decides width/signedness/float-kind.
 *
 * @field is_float  false for an integer literal (`value` holds it, any width u8..u64/i8..i64),
 *                   true for a float literal (f32/f64; `fval` holds it, default f64)
 * @field value      the raw integer literal value as a sign+64-bit-magnitude pair (meaningful
 *                    only when `!is_float`) ‚Äî see `NumInt`
 * @field fval       the raw float literal value (meaningful only when `is_float`)
 */
pub type Number = struct { is_float: bool; value: NumInt; fval: f64 }
pub type Var = struct { name: str }   // a variable reference (reading)
pub type StrLit = struct { text: str }   // "‚Ä¶"  (B.36)
pub type ByteLit = struct { value: byte }   // b'x' (B.36)
pub type CharLit = struct { bytes: str }   // c'x' ‚Äî one UTF-8 codepoint (1‚Äì4 bytes), carried as its raw UTF-8
pub type BoolLit = struct { value: bool }   // true / false (LEGISLATION ¬ß75)
pub type NullLit = struct { }   // null (REBOOT_PLAN ¬ß202) ‚Äî no payload; typed `T?` by the checker
pub type Binary = struct { op: lexer::TokenKind; left: Expr; right: Expr }   // any binary op
pub type Unary = struct { op: lexer::TokenKind; operand: Expr }   // - ~ ! (prefix)
/**
 * One continuation term of a `Compare` chain (`<op> operand`) ‚Äî e.g. the `< c` in `a < b < c`.
 * ((TR3) `pub` so the structural-trait synthesis can build a `Compare` node directly.)
 */
pub type CmpTerm = struct { op: lexer::TokenKind; operand: Expr }
pub type Compare = struct { first: Expr; rest: []CmpTerm }   // a<b<c chain, kept as written (M.3)
/**
 * A call expression `f(x)` / `lexer::foo(x)` / `Cell<i64>::make(7)`.
 *
 * @param callee    the callee path (the function or generic-instance factory owner)
 * @param args      the positional/named argument expressions
 * @param arg_names PARALLEL to `args` (DEFARGS 2026-07-01) ‚Äî "" = positional, else the NAMED param this
 *                  arg targets (`f(name = x)`); named-LAST ordering enforced at parse time
 * @param type_args (#254 L5) explicit `Cell<i64>::make(‚Ä¶)` construction-site generic args ‚Äî empty for a
 *                  bare call. TRANSIENT: the `.tkb` codec persists `checker::TCall`, not `parser::Call`
 */
pub type Call = struct { callee: Path; args: []Expr; arg_names: []str; type_args: []TypeExpr }
pub type IfExpr = struct {   // if/else is an EXPRESSION (B.20)
    cond: Expr
    then_blk: []Statement
    has_else: bool
    else_blk: []Statement
}
pub type MatchExpr = struct { subject: Expr; arms: []Arm }   // match is an EXPRESSION (B.15)

// --- postfix access & cast (F2) ‚Äî recursive over Expr (compiler-managed indirection) ---
pub type FieldAccess = struct { receiver: Expr; field: str }   // x.field ‚Äî read a struct field (the checker's own `s.token`/`b.left` shape; B.29)
pub type SafeFieldAccess = struct { receiver: Expr; field: str }   // x?.field ‚Äî null-propagating access (REBOOT_PLAN ¬ß203)
pub type Coalesce = struct { left: Expr; right: Expr }   // x ?? y ‚Äî Elvis / null-coalescing (REBOOT_PLAN ¬ß203)
pub type MethodCall = struct { receiver: Expr; method: str; args: []Expr }   // recv.method(a, ‚Ä¶) ‚Äî B.29 instance call via `.`; method *checking* is deferred (M.4)
pub type SafeMethodCall = struct { receiver: Expr; method: str; args: []Expr }   // recv?.method(a, ‚Ä¶) ‚Äî null-propagating method call (NP-OOP, issue #116)
pub type Cast = struct { expr: Expr; target: TypeExpr }   // x to T ‚Äî explicit conversion; preserves‚Üíok / loses‚Üícompile-error (E7; M.0+M.1)
/**
 * Borrow ‚Äî the prefix `&x` safe mutable-borrow expression (AL wave F1). Takes a live
 * borrow of the operand lvalue, surfacing the auto-ref that is implicit in argument
 * position today as an explicit operator. Types to `Reference<T>`; mutability is inferred
 * from the operand's binding + the consuming position (bare `&x`, no `&mut`). A borrow of
 * an immutable (`let`) binding in mutable position is a checker error (auto-enforces F2).
 * `&` is the SAFE `ref` surface here ‚Äî NOT the unsafe raw-pointer sigil (that stays unsafe;
 * `*`/deref untouched, prospec√ß√£o ¬ß12).
 */
pub type Borrow = struct { operand: Expr }   // &x ‚Äî safe mutable borrow (AL wave F1)
pub type PathExpr = struct { path: Path }   // a qualified path as a VALUE ‚Äî Enum::Member (e.g. PrimKind::U32), module statics (P2; the F2/Part-1 AST had only single-name Var)
pub type StructLit = struct { type_path: Path; type_args: []TypeExpr; field_names: []str; field_vals: []Expr }   // Name { field = value, ‚Ä¶ } ‚Äî a struct VALUE constructor (W4a); (W9.4) type_args = explicit `Foo<i64>{ ‚Ä¶ }` generic args (empty for bare `Foo { ‚Ä¶ }`); parallel slices (.len replaces nfields)
pub type Index = struct { receiver: Expr; index: Expr }   // recv[index] ‚Äî str‚Üíbyte, []T‚ÜíT (W5-idx)
// Format spec for a single $"‚Ä¶{expr:spec}‚Ä¶" hole. Three variants:
//   FSpecNone    ‚Äî no colon in hole (existing behavior)
//   FSpecStatic  ‚Äî `:literal` ‚Üí static spec string (e.g. "F2")
//   FSpecDynamic ‚Äî `:[arg1, arg2, ‚Ä¶]` ‚Üí arg expressions evaluated at runtime
pub type FSpecNone = struct { }
pub type FSpecStatic = struct { s: str }
pub type FSpecDynamic = struct { args: []Expr }
pub type FSpecKind = variant FSpecNone | FSpecStatic | FSpecDynamic
pub type FSpec = struct { kind: FSpecKind }
// `$"pre {a} mid {b} post"` ‚Äî string interpolation (self-host parity). The string is
// pieces[0] ++ str(holes[0]) ++ pieces[1] ++ ‚Ä¶ ++ pieces[nholes] ‚Äî so pieces.len == holes.len + 1.
// Pieces are DECODED literal str spans (escapes resolved, like StrLit); each hole is a full Expr.
// specs[i] carries the optional format spec for holes[i] (specs.len == holes.len).
pub type Interp = struct { pieces: []str; holes: []Expr; specs: []FSpec }   // $"‚Ä¶{expr}‚Ä¶" (self-host parity)
// `<expr> in [ e0, e1, ‚Ä¶ ]` ‚Üí bool (Phase 2). True iff the LHS equals any element; the LHS is
// EVALUATED ONCE. The `[ ‚Ä¶ ]` is a SPECIAL membership-set syntax valid ONLY here (no general
// array literal). Empty set `x in []` is allowed ‚Üí always false.
pub type InExpr = struct { lhs: Expr; elems: []Expr }   // x in [ ‚Ä¶ ] ‚Äî membership test (Phase 2)
pub type ArrayElem = struct { is_spread: bool; expr: Expr }   // one element in an array literal: plain (is_spread=false) or spread (is_spread=true, ..expr)
pub type ArrayLit = struct { elements: []ArrayElem }   // [ e0, e1, ‚Ä¶ ] ‚Äî a slice/array literal (Increment B+); element type unified by the checker
// (W10) a closure LITERAL `(params) => expr` / `(params) => { ‚Ä¶ }` ‚Äî an anonymous function value
// (NO `fn` keyword). A param's type is OPTIONAL (`has_type` false ‚áí inferred from the target type,
// per the W10 ruling). The body is a STATEMENT BLOCK (a `=> expr` form is stored as one trailing
// ExprStmt, like a fn body), so the trailing value is the closure's result. The return type is
// inferred (no `-> R` on a literal). The checker types it to a `Func` and lifts it to a top-level
// function + capture env. (`.type` ends up the closure's Func type.)
pub type LambdaParam = struct { name: str; has_type: bool; type_ann: TypeExpr }
pub type Lambda = struct { params: []LambdaParam; body: []Statement }

// (C1-POS/E1) Expr is a STRUCT WRAPPER over the variant of node kinds ‚Äî mirroring the typed
// `TExpr` (tast.tks) and the C `tk_expr` (ast.h), so EVERY expression node carries its 1-based
// source position. The parser stamps line/col from the node's first token; the checker copies
// it onto the typed node and onto type-errors, so a message points at the failing expression.
pub type ExprKind = variant Number | Var | Call | IfExpr | MatchExpr | StrLit | ByteLit | CharLit | BoolLit | NullLit | Binary | Unary | Compare | FieldAccess | SafeFieldAccess | Coalesce | MethodCall | SafeMethodCall | Cast | PathExpr | StructLit | Index | Interp | InExpr | ArrayLit | Lambda | Borrow
pub type Expr = struct { kind: ExprKind; line: u32; col: u32 }

// --- statements ---
pub type BindKind = enum { Let; Mut; Const }
pub type SimpleName = struct { name: str }
pub type DestructurePattern = struct { names: []str }   // let { x; y } = ‚Ä¶ (B.13 partial)
pub type BindTarget = variant SimpleName | DestructurePattern

pub type Binding = struct {   // let/mut/const TARGET [: T] = value
    kind: BindKind
    target: BindTarget
    has_type: bool
    type_ann: TypeExpr   // the parsed annotation (A.8)
    value: Expr
}
/**
 * AssignKind ‚Äî the target shape of an assignment (#88). One of four, tagged on `Assign`/`TAssign`:
 *
 * @field Simple    `name op= value` ‚Äî the bare binding `name` (deref=false; target = no_expr()).
 * @field RefDeref  `name.value op= value` ‚Äî write THROUGH a `Ref<T>` handle `name` (deref=true, the
 *                  legacy MEM-1b-ii flag; target = no_expr()).
 * @field Field     `recv.field op= value` ‚Äî a struct/class field write; `target` is the LHS field-access
 *                  EXPR (a FieldAccess, arbitrarily nested); `name`/`deref` unused.
 * @field Index     `ids[i] op= value` ‚Äî a slice/array ELEMENT write; `target` is the LHS index EXPR (an
 *                  `Index{receiver,index}`); `name`/`deref` unused. Appended LAST so the three legacy
 *                  ordinals (and thus the TKB `assign_kind_byte` layout) are unchanged. `deref` stays a
 *                  plain bool == (kind==RefDeref); Field/Index both carry the general lvalue in `target`
 *                  (see `assign_has_target`).
 */
pub type AssignKind = enum { Simple; RefDeref; Field; Index }
pub type Assign = struct { kind: AssignKind; name: str; op: lexer::TokenKind; value: Expr; deref: bool; target: Expr }   // x = / += / ‚Ä¶ (B.4); see AssignKind above

/**
 * assign_has_target ‚Äî does an `AssignKind` carry a general lvalue EXPRESSION in `Assign.target` /
 * `TAssign.target`? True for the two expr-target shapes ‚Äî `Field` (`recv.field`) and `Index`
 * (`ids[i]`) ‚Äî and false for `Simple` / `RefDeref` (which write a bare `name`). Every AST/TAST walk
 * that descends into a field assignment's `target` must descend an index assignment's `target` too
 * (both hold sub-expressions naming free variables), so the two share this single predicate.
 *
 * @param kind  the assignment's target discriminant
 * @return      true iff `target` holds a walkable lvalue expression (`Field` or `Index`)
 */
pub fn assign_has_target(kind: AssignKind) -> bool {
    match kind {
        AssignKind::Field => true
        AssignKind::Index => true
        _ => false
    }
}
pub type Return = struct { has_value: bool; value: Expr }   // `return [expr]` ‚Äî bare `return` (no value) has has_value=false, value a placeholder (B.20; P4a)
/**
 * `[LABEL:] loop [<head>] { ‚Ä¶ }` (M.5, #517). The head is fully desugared by the parser: `init`
 * holds the run-once, LOOP-SCOPED preamble (counter/bound/`_first` for range & 3-part, `_it` for
 * for-each; empty for infinite & while) and `body` already contains the folded condition-break, the
 * guarded step, and/or the closure-iterator `match`. `label` empty (len 0) = unlabeled.
 *
 * @field label the UPPER_SNAKE prefix label, or "" when unlabeled
 * @field init  the loop-scoped preamble, run once before the first iteration; it does NOT leak past
 *              the loop (checker scope / VM base-pop / codegen brace)
 * @field body  the iteration body (folded head + user statements)
 */
pub type LoopStmt = struct { label: str; init: []Statement; body: []Statement }
pub type BreakStmt = struct { label: str }   // break [NAME] ‚Äî label empty = innermost loop
pub type ContinueStmt = struct { label: str }   // continue [NAME] ‚Äî label empty = innermost loop
pub type ExprStmt = struct { expr: Expr }   // a bare expression on its own line
// `defer { stmts }` (C7.18) ‚Äî scoped cleanup block; executes LIFO at ANY scope exit
// (normal return, early return inside a loop, break out of a function).
// Panic does NOT run deferred blocks (simplifies implementation).
// Nested `defer` is rejected by the checker.
pub type DeferStmt = struct { body: []Statement }

/**
 * `adopt [name] { stmts }` ‚Äî opens an ADOPTER region; every object allocated lexically inside
 * belongs to it, and the closing brace BULK-drops the whole subtree at once (cycles irrelevant ‚Äî
 * nothing is freed per-object). The C1 closer of the memory remodel (¬ß1 L4). `adopt` is a
 * CONTEXTUAL statement head (not a hard keyword) recognized by ident text at statement position.
 *
 * @field name  the optional bound name (`adopt r { ‚Ä¶ }`); empty = anonymous adopter. The region
 *              is opened/dropped either way; the name only matters when a future increment lets
 *              code reference the region handle.
 * @field body  the statements executed inside the adopter region.
 */
pub type AdoptStmt = struct { name: str; body: []Statement }

pub type Statement = variant Binding | Assign | Return | LoopStmt | BreakStmt | ContinueStmt | ExprStmt | DeferStmt | AdoptStmt

// --- generic type-parameter CONSTRAINTS (W11/S6, 2026-07-01) -----------------------------
// `<T: ConstraintExpr>` ‚Äî a DEDICATED boolean grammar over NOMINAL atoms (variant/struct
// names), syntactically distinct from a type-expression `|` (that's a type UNION; this is a
// boolean AND/OR over membership tests). `&` binds tighter than `|`: `C1 & C2 | C3` parses as
// `(C1 & C2) | C3`. An atom is a bare name; the checker rejects `?`/null/void atoms (a
// constraint targets a concrete nominal type, never a use-position nullable/void). Checked AT
// MONOMORPHIZATION (when a generic is instantiated with a concrete type), never at definition
// (an unconstrained T stays OPAQUE ‚Äî store/pass/return only; operating on members needs a
// constraint). NoConstraint is the sentinel for a type-param with no `: ‚Ä¶` clause, so
// Function/TypeDecl.type_constraints stays PARALLEL to type_params (same length, index i's
// constraint governs type_params[i]) without an Optional wrapper.
pub type ConstraintAtom = struct { name: str }   // a nominal variant/struct name
pub type ConstraintAnd = struct { left: ConstraintExpr; right: ConstraintExpr }   // C1 & C2 ‚Äî both must hold
pub type ConstraintOr = struct { left: ConstraintExpr; right: ConstraintExpr }   // C1 | C2 ‚Äî either must hold
pub type NoConstraint = struct { }   // sentinel: the type-param has no `: ‚Ä¶` clause
pub type ConstraintExpr = variant ConstraintAtom | ConstraintAnd | ConstraintOr | NoConstraint

// --- top-level items ---
pub type Param = struct { name: str; has_type: bool; type_ann: TypeExpr; is_params: bool; has_default: bool; default_expr: Expr }   // immutable (B.21); is_params = C#-style variadic modifier (2026-07-01), trailing-only, type_ann must be a Slice; has_default/default_expr = DEFARGS (2026-07-01) ‚Äî TRAILING-ONLY (once one param defaults, every later param must too), default_expr valid iff has_default; has_type = OOP A1 (2026-07-01) ‚Äî false ONLY for a struct method's 1st param (the RECEIVER, name free, type injected by the checker as the enclosing struct); every other param is always typed (type_ann valid iff has_type)

/** A dependency-injection lifetime (W10c/MEM-3). `None` = the type carries no
 *  `#singleton`/`#scoped`/`#transient` annotation; the three others are the design's three
 *  DI lifetimes ‚Äî a singleton lives in the root region, a scoped instance in its owning
 *  region (walking up the arena tree), a transient one is freshly built per use. */
pub type DiKind = enum { None; Singleton; Scoped; Transient }

/** One `#inject(name: Type)` binding on a fn overlay (W10c/MEM-3). `has_key`/`key` carry
 *  an optional `@Key` selector ‚Äî parsed so issue #173 (keys + `#wire`) needs no AST churn,
 *  but rejected by the core-DI checker (keys are out of core scope). `line`/`col` point at
 *  the binding name for diagnostics. */
pub type InjectBinding = struct { name: str; type_ann: TypeExpr; has_key: bool; key: str; line: u32; col: u32 }

// Visibility ‚Äî a declaration's REACH (LEGISLATION "Visibility ‚Äî pub vs exp"; B.9).
// Private (default, no keyword) = own namespace only; Pub = across the project's
// namespaces (not in the binary header); Exp = exported in the `.tkh` (the public ABI),
// pub by definition. Ordered by increasing reach: Private < Pub < Exp.
pub type Visibility = enum { Private; Pub; Exp }

pub type Function = struct {
    name: str
    type_params: []str   // generic type-parameter names (S4 ‚Äî empty for a non-generic fn; e.g. `fn id<T>` ‚Üí ["T"])
    type_constraints: []ConstraintExpr   // (W11/S6) PARALLEL to type_params (same length); NoConstraint{} = no `: ‚Ä¶` clause
    params: []Param
    has_return: bool   // `-> ret` present? (absent = Unit return; P5a)
    return_type: TypeExpr   // the return type (valid iff has_return)
    body: []Statement
    vis: Visibility   // private (default) / pub / exp
    has_doc: bool   // a `/** ‚Ä¶ */` doc precedes it?
    doc: str   // the doc span (valid iff has_doc)
    line: u32   // the name's 1-based source line (W-loc-2 diagnostics)
    col: u32   // the name's 1-based source column (W-loc-2 diagnostics)
    is_test: bool   // a `#test` attribute precedes it? (D2 ‚Äî run by `teko test` / the build gate)
    is_extern: bool   // an `extern` foreign-function declaration? (C7.1a ‚Äî no body)
    c_symbol: str   // the C symbol it binds (valid iff is_extern)
    from_lib: str   // the providing library ("" = implicit libc; valid iff is_extern)
    os_guard: str   // a `#os("‚Ä¶")` conditional-compile guard ("" = all OSes; C7.1f)
    is_intern: bool   // (W10b.CLASS, 2026-07-01) visible to inheritors (combines WITH vis, not a 4th tier); struct members always false
    is_abstract: bool   // `abstract fn` ‚Äî signature only, no body (abstract classes only)
    is_virtual: bool   // `virtual fn` ‚Äî overridable by a derived class
    is_override: bool   // `override fn` ‚Äî overrides a base virtual/abstract method
    has_inject: bool
    injects: []InjectBinding
    /**
     * An `unsafe fn` ‚Äî the owner-total risk marker on a namespace function (U1, the
     * 0.1.0.0-beta memory+unsafe remodel ¬ß2). `unsafe` is a contextual keyword (not
     * reserved), so this flag is parsed but NOT enforced here: the checker (U2) is
     * what makes an unsafe fn's contents actually unlock the risky operations. A
     * method's `Function` (inside a struct/class body) always carries `is_unsafe =
     * false` ‚Äî per design, unsafe-ness attaches to the ENCLOSING TypeDecl, not to
     * individual methods; `TypeDecl.is_unsafe` is the sole source of truth there.
     */
    is_unsafe: bool
}
/**
 * StructBody ‚Äî a `struct [I & ‚Ä¶] { fields; methods; consts }` body (OOP A1). A struct's members
 * (fields + methods) stay ALL PUBLIC. `implements` is the `struct I1 & I2 { ‚Ä¶ }` interface list,
 * empty when the struct declares none.
 *
 * @param fields      the interleaved `name: T` fields, in source order
 * @param methods     the interleaved `fn` decls ‚Äî an untyped 1st param marks an INSTANCE method
 *                    (the receiver), else a STATIC method
 * @param implements  the interface names the struct conforms to (`& I1 & I2`), empty when none
 * @param consts      the static type-member `const NAME: T = ‚Ä¶` declarations (#594 crumb 7); each
 *                    occupies NO layout slot and is resolved by `StructName::NAME`
 */
pub type StructBody = struct { fields: []Field; methods: []Function; implements: []str; consts: []ConstDecl }
/**
 * One field of a struct/class/trait body.
 *
 * `vis` is the field's REACH (W10b.CLASS, 2026-07-01) ‚Äî the usual Private/Pub/Exp; `is_intern`
 * widens it to "also visible to inheritors" (orthogonal, not a 4th Visibility tier ‚Äî see
 * Visibility's own doc). A struct's Field always carries vis=Pub/is_intern=false (struct members
 * stay all-public per W10b.0.A); only class-body fields actually vary these.
 *
 * `has_doc`/`doc` (issue #285) mirror Function's own: a leading Javadoc directly above the field
 * attaches here, so a class/struct body can carry a full-Javadoc per field (W15).
 *
 * @param name       the field's name
 * @param type_ann   the field's declared type
 * @param vis        the field's reach (Private/Pub/Exp)
 * @param is_intern  visible to inheritors? (class bodies only; always false for a struct field)
 * @param has_doc    a Javadoc directly precedes this field?
 * @param doc        the doc-comment's text (valid iff has_doc)
 */
pub type Field = struct { name: str; type_ann: TypeExpr; vis: Visibility; is_intern: bool; has_doc: bool; doc: str }
pub type EnumBody = struct { members: []str }   // member names, in order
/**
 * A `flags` type body: member names + their power-of-2 bit-values (C8.3 assigns member `i`
 * ‚Üí `1 << i`; C8.6 serializes). The bit-value carrier is `u64` (drop-128, 2026-07-24), so a
 * flags type is capped at 64 members ‚Äî bit 63 is the last representable; a 65th member is a
 * checker error naming the cap.
 *
 * @field members  the member names, in declaration order
 * @field values    the resolved bit-value of each member, PARALLEL to `members` (‚â§ 64 entries)
 */
pub type FlagsBody = struct { members: []str; values: []u64 }
pub type VariantBody = struct { type_expr: TypeExpr }   // a union (A.8)
pub type AliasBody = struct { alias: TypeExpr }   // `type Name = <type-expr>` ‚Äî a TRANSPARENT alias (self-host parity)
pub type ExternBody = struct { }   // `extern type Name` ‚Äî an OPAQUE foreign handle (C7.1a; lowers to `void *`)
// (W10b.CLASS, 2026-07-01) a class's KIND ‚Äî Teko INVERTS the usual default: SEALED (final,
// instantiable, NOT inheritable) is the DEFAULT (bare `class`); `abstract class` = inheritable,
// NOT instantiable; `virtual class` = instantiable AND inheritable.
pub type ClassKind = enum { Sealed; Abstract; Virtual }
/**
 * ClassBody ‚Äî a `type C = <kind> [Base[(binding)]] [& I1 & I2 ‚Ä¶] { fields; methods; consts }` body
 * (W10b.CLASS). AT MOST one base class (itself Abstract or Virtual, enforced by the checker). Members
 * (fields + methods) are PRIVATE BY DEFAULT (`pub`/`intern` widen) ‚Äî the inverse of a struct.
 *
 * @param kind              SEALED (default), Abstract, or Virtual (see ClassKind)
 * @param has_base          does this class extend a base class?
 * @param base_name         the base class's name (valid iff has_base)
 * @param has_base_binding  is a base-binding name declared (`Base(parent)`)?
 * @param base_binding_name the name INSTANCE methods use to reach the base object (valid iff has_base_binding)
 * @param implements        the `& I1 & I2` interface/derive list
 * @param fields            the interleaved `name: T` fields, in source order
 * @param methods           the interleaved `fn` decls (instance/static, per receiver shape)
 * @param consts            the static type-member `const NAME: T = ‚Ä¶` declarations (#594 crumb 7);
 *                          each occupies NO layout slot and is resolved by `ClassName::NAME` (a
 *                          subclass reaches a base's `pub`/`exp` member const by name)
 */
pub type ClassBody = struct {
    kind: ClassKind
    has_base: bool
    base_name: str
    has_base_binding: bool
    base_binding_name: str
    implements: []str
    fields: []Field
    methods: []Function
    consts: []ConstDecl
}
// (W10b.IF) an INTERFACE ‚Äî a PURE SIGNATURE CONTRACT: `type X = interface [I1 & I2 ‚Ä¶] { fn sig; ‚Ä¶ }`.
// `extends: []str` ‚Äî the interfaces this one extends (multiple inheritance; the `I1 & I2` list between
// `interface` and `{`). `methods: []Function` ‚Äî INSTANCE-method SIGNATURES only (each is a bodyless
// `Function`: 1st param untyped = the receiver; NO body, NO statics, NO default bodies; all members
// public). A type conforms by providing every method (transitively through `extends`) with a matching
// signature. An interface has NO runtime representation yet (dynamic dispatch = ROUND 3); it is a
// compile-time contract only, so codegen/VM emit nothing for it and reject it as a value type.
pub type InterfaceBody = struct { extends: []str; methods: []Function }
/**
 * TraitBody ‚Äî a `trait { fields; methods; consts }` body (TR0): a struct-shaped, NON-instantiable
 * bundle a struct/class DERIVES (`type Post = struct Timestamped { ‚Ä¶ }`, the `&`-list position).
 * The checker FOLDS derived traits into each deriver before typing (fold_traits), so codegen/VM
 * never see a trait in a value position; the decl itself emits nothing (like InterfaceBody).
 *
 * @param fields   the provided members, folded into the deriver (class field-flattening)
 * @param methods  a method WITH a body is PROVIDED (overridable); a bodyless one is a REQUIREMENT
 *                 the deriver must satisfy (like interface conformance)
 * @param consts   the static type-member `const NAME: T = ‚Ä¶` declarations (#594 crumb 7); each
 *                 folds into every deriver like a field, resolved by `DeriverName::NAME`
 */
pub type TraitBody = struct { fields: []Field; methods: []Function; consts: []ConstDecl }
pub type TypeBody = variant StructBody | EnumBody | FlagsBody | VariantBody | AliasBody | ExternBody | ClassBody | InterfaceBody | TraitBody   // pub: TypeDecl.body surface + the .tkb codec (C7.16)
pub type TypeDecl = struct {   // nominal (B.13)
    name: str
    type_params: []str   // generic type-parameter names (S4 ‚Äî empty for a non-generic type; e.g. `type Box<T>` ‚Üí ["T"])
    type_constraints: []ConstraintExpr   // (W11/S6) PARALLEL to type_params (same length); NoConstraint{} = no `: ‚Ä¶` clause
    body: TypeBody
    vis: Visibility   // private (default) / pub / exp
    has_doc: bool
    doc: str   // the doc span (valid iff has_doc)
    line: u32   // the name's 1-based source line (W-loc-2 diagnostics)
    col: u32   // the name's 1-based source column (W-loc-2 diagnostics)
    di_kind: DiKind
    has_di_key: bool
    di_key: str
    /**
     * An `unsafe type M = struct|class { ‚Ä¶ }` ‚Äî the owner-total risk marker on a
     * type declaration (U1, the 0.1.0.0-beta memory+unsafe remodel ¬ß2). `unsafe` is
     * a contextual keyword (not reserved), so this flag is parsed but NOT enforced
     * here: the checker (U2) is what makes the contagion-by-composition and
     * uncolored-calls rules bite. A trait/interface/enum/flags/alias/extern TypeDecl
     * likewise just carries this flag (default `false` unless `unsafe` precedes it).
     */
    is_unsafe: bool
    /**
     * A `#must_free type M = struct|class { ‚Ä¶ }` ‚Äî the RELEVANT-type marker (S2, the
     * 0.1.0.0-beta memory+unsafe remodel #336), the DUAL of affine: a value of this type must
     * be consumed (freed or moved) on at least one control-flow path, or the checker's local
     * consume-or-fail dataflow (`type_function`) rejects the function at compile time. Parsed
     * as a plain `#`-attribute (no payload), like `#singleton`/`#scoped`/`#transient`, but it
     * may ONLY precede a `type` (never a `fn`/`flags`, never a `let`). Default `false` unless
     * `#must_free` precedes the declaration.
     */
    must_free: bool
}
/**
 * A `use` declaration, in one of three forms (S1, the 0.1.0.0-beta remodel ¬ß3.1):
 * bare `use a::b`, aliased `use a::b as c`, or grouped `use a::b::[ X, Y ]`.
 */
pub type UseDecl = struct {
    /** the owning namespace path (`a::b`), common to all three forms. */
    path: Path
    /** true iff an `as alias` follows the path (never true for the grouped form). */
    has_alias: bool
    /** the bound alias name (valid iff `has_alias`; `""` for bare/grouped forms). */
    alias: str
    /**
     * the grouped import's names (`use a::b::[ X, Y ]` ‚Üí `["X", "Y"]`); EMPTY for the two
     * existing forms (bare and aliased) ‚Äî an empty list is the "not a grouped import"
     * sentinel the checker's `build_aliases` guards on.
     */
    names: []str
}

/**
 * ConstDecl ‚Äî a module-level named compile-time constant `const NAME: Type = init`
 * (#594). Distinct from the local `BindKind::Const` binding (`parse_stmt.tks`): a
 * ConstDecl is a top-level Decl with visibility, a mandatory type annotation, and a
 * const-expr initializer (validated by `teko::checker::is_const_expr`). It carries
 * no scope and opens no arena ‚Äî the checker inlines it (scalars) or the backend
 * materializes it in rodata (aggregates, C-agg-2).
 *
 * @param name    the constant's identifier
 * @param ty      the mandatory declared type annotation
 * @param init    the const-expr initializer
 * @param vis     Pub/Exp/private, mirroring a function's
 * @param has_doc whether a doc-comment was attached
 * @param doc     the attached doc-comment text (valid iff has_doc)
 * @param line    the `const` keyword's source line
 * @param col     the `const` keyword's source column
 * @since #594
 */
pub type ConstDecl = struct { name: str; ty: TypeExpr; init: Expr; vis: Visibility; has_doc: bool; doc: str; line: u32; col: u32 }

// --- R-main: a `.tks` file is a MAIN (executable entry) or a MODULE. ---
/**
 * A top-level declaration ‚Äî a module's content: a `fn` (Function), a `type`/`flags`
 * (TypeDecl), or a module-level `const` (ConstDecl, #594).
 *
 * @since #594 widened with ConstDecl (was `Function | TypeDecl`).
 */
pub type Decl = variant Function | TypeDecl | ConstDecl
pub type MainFile = struct { uses: []UseDecl; body: []Statement }   // main.tks: the `use` header + the VIRTUAL MAIN's body (statements only ‚Äî no type/fn decls)
pub type Module = struct { uses: []UseDecl; decls: []Decl }   // a module: the `use` header + declarations (no loose statements)
type File = variant MainFile | Module   // a `.tks` is exactly one; the file's role decides (main.tks ‚áî an executable `.tkp`)

// --- the FLATTENED item/program ‚Äî the CHECKER's input view (mirror of the C tk_item /
//     tk_program in ast.h). The parser produces File/Module/Decl; the DRIVER flattens
//     them into this `Program` of `Item`s, which the checker (collect/typer) consumes.
//     Each `Item` is a tagged payload (the C union) PLUS the namespace it came from (A3
//     provenance for codegen name-mangling; resolution/typing IGNORE it). ---
/**
 * The C `tk_item` tag+union, as a Teko variant ‚Äî a flattened top-level item's
 * payload: a `use`, a loose statement (main files), a `fn`, a `type`/`flags`, or a
 * module-level `const` (ConstDecl, #594).
 *
 * @since #594 widened with ConstDecl (was `UseDecl | Statement | Function | TypeDecl`).
 */
pub type ItemKind = variant UseDecl | Statement | Function | TypeDecl | ConstDecl
pub type Item = struct { content: ItemKind; namespace: str; file: str }   // a flattened top-level item + its source namespace (A3) + source file (W-loc-2: assemble tags it so a flattened-program error resolves to file:line:col; empty on the single-file compile/run path)
pub type Program = struct { items: []Item }   // the flat item list the checker consumes
