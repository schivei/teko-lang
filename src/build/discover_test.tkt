// src/build/discover_test.tkt — tests for teko::build file-set discovery + namespace
// mapping. #test collected. Uses teko::assert::is_true (the migrated form; B2).

// does the discovered set contain a file at `path` mapped to namespace `ns`?
fn has(files: []SourceFile, path: str, ns: str) -> bool {
    for f in files {
        if f.path == path && f.namespace == ns { return true }
    }
    false
}

#test
fn maps_subdir_file_to_namespace_with_colons() {
    // a file in a subdir → namespace = root + "::" + dir segment.
    match discover("teko", "src") {
        []SourceFile as files => {
            teko::assert::is_true(has(files, "src/lexer/lexer.tks", "teko::lexer"))
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn maps_source_root_file_to_bare_root() {
    // a file DIRECTLY under source → the bare root namespace (source invisible).
    match discover("teko", "src") {
        []SourceFile as files => {
            teko::assert::is_true(has(files, "src/core.tks", "teko"))
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn includes_tkt_files() {
    // .tkt tests are part of the file set (they live beside the code they test).
    match discover("teko", "src") {
        []SourceFile as files => {
            teko::assert::is_true(has(files, "src/build/discover_test.tkt", "teko::build"))
        }
        error => teko::assert::is_true(false)
    }
}
