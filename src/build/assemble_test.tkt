// src/build/assemble_test.tkt — tests for teko::build multi-file assembly (A3).
// #test collected. Uses teko::assert::is_true (the migrated form; B2).
//
// assemble takes the discovered file set (A2) and MERGES every file's top-level items
// into ONE program, tagging each item with its SourceFile namespace. These tests drive
// it over the compiler's own tree (name="teko", source="src") — the whole project is
// read, parsed, and merged in one pass (M.1).

use teko::parser

// how many items did assembly merge from the discovered set?
fn item_count(p: parser::Program) -> u64 {
    p.items.len
}

#test
fn merges_the_whole_project_into_one_program() {
    // discover the compiler's own sources, then assemble them. A non-empty merged
    // program proves the file set was read, parsed, and flattened into ONE program.
    match discover("teko", "src") {
        []SourceFile as files => {
            match assemble(files) {
                parser::Program as prog => teko::assert::is_true(item_count(prog) > 0)
                error           => teko::assert::is_true(false)
            }
        }
        error => teko::assert::is_true(false)
    }
}

#test
fn empty_file_set_assembles_to_an_empty_program() {
    // no files in, no items out — the merge is total over the (empty) input.
    let none: []SourceFile = []
    match assemble(none) {
        parser::Program as prog => teko::assert::is_true(item_count(prog) == 0)
        error           => teko::assert::is_true(false)
    }
}
