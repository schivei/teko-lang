// src/build/manifest_test.tkt — tests for teko::build manifest reader. #test collected.
// (Uses bare `assert`, the current .tkt convention; teko::assert migration is crumb B2.)

// did the parse succeed?
fn parses(src: str) -> bool {
    match parse_manifest(src) { Manifest => true; error => false }
}

#test
/**
 * tests_section_malformed_regression_errors — a `regression` value that is neither a quoted string
 * nor an array is an honest error (M.3 — no coercion). @since 0.3.0.29
 *
 * @return void
 */
fn tests_section_malformed_regression_errors() {
    teko::assert::is_false(parses("name = \"app\"\nsource = \"src\"\n[tests]\nregression = 42\n"))
    teko::assert::is_true(parses("name = \"app\"\nsource = \"src\"\n[tests]\nregression = [\"a\"]\n"))
}

#test
/**
 * test_regression_files_is_an_explicit_ordered_file_list — `[tests] regression` parses into
 * `Manifest.test_regression_files`, in list order, with the bare-string shorthand normalizing to a
 * 1-element list (0.3.1 C0 — no directory discovery, no glob).
 *
 * @return void
 */
fn test_regression_files_is_an_explicit_ordered_file_list() {
    match parse_manifest("name = \"app\"\nsource = \"src\"\n[tests]\nregression = [\"a.tkr\", \"b/c.tkr\"]\n") {
        Manifest as m => {
            teko::assert::is_true(m.test_regression_files.len == 2)
            teko::assert::is_true(m.test_regression_files[0] == "a.tkr")
            teko::assert::is_true(m.test_regression_files[1] == "b/c.tkr")
        }
        error => teko::assert::is_true(false)
    }
    match parse_manifest("name = \"app\"\nsource = \"src\"\n[tests]\nregression = \"solo.tkr\"\n") {
        Manifest as m => { teko::assert::is_true(m.test_regression_files.len == 1); teko::assert::is_true(m.test_regression_files[0] == "solo.tkr") }
        error => teko::assert::is_true(false)
    }
    match parse_manifest("name = \"app\"\nsource = \"src\"\n") {
        Manifest as m => teko::assert::is_true(m.test_regression_files.len == 0)
        error => teko::assert::is_true(false)
    }
}

/**
 * `[artifact] abi = "c"` sets the reverse-FFI ABI on the manifest; its absence (or any other value)
 * leaves the native Teko ABI (empty string) — FFI-D.
 */
#test
fn ffx_manifest_parses_abi_c() {
    match parse_manifest("name = \"lib\"\nsource = \"src\"\n[artifact]\nkind = \"static\"\nabi = \"c\"\n") {
        Manifest as m => teko::assert::is_true(m.abi == "c")
        error => teko::assert::is_true(false)
    }
    match parse_manifest("name = \"app\"\nsource = \"src\"\n[artifact]\nkind = \"binary\"\n") {
        Manifest as m => teko::assert::is_true(m.abi == "")
        error => teko::assert::is_true(false)
    }
}
