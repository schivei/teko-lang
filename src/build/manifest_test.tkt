// src/build/manifest_test.tkt — tests for teko::build manifest reader. #test collected.
// (Uses bare `assert`, the current .tkt convention; teko::assert migration is crumb B2.)

// did the parse succeed?
fn parses(src: str) -> bool {
    match parse_manifest(src) { Manifest => true; error => false }
}

#test
/**
 * tests_section_malformed_regression_errors — a `regression` value that is neither a quoted string
 * nor an array is an honest error (M.3 — no coercion). @since 0.3.0.29
 *
 * @return void
 */
fn tests_section_malformed_regression_errors() {
    teko::assert::is_false(parses("name = \"app\"\nsource = \"src\"\n[tests]\nregression = 42\n"))
    teko::assert::is_true(parses("name = \"app\"\nsource = \"src\"\n[tests]\nregression = [\"a\"]\n"))
}
