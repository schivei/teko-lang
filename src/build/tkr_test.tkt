/**
 * tkr_parses — did the `.tkr` source parse successfully?
 *
 * @param src  the `.tkr` text
 * @return     true when `parse_tkr` returns a `Tkr`
 */
fn tkr_parses(src: str) -> bool {
    match parse_tkr(src) { Tkr => true; error => false }
}

#test
/**
 * tkr_rejects_malformed — a malformed line (missing `=`), an unknown `kind`, and a non-list `args`
 * value are honest errors (M.3); a well-formed source still parses.
 *
 * @return void
 */
fn tkr_rejects_malformed() {
    teko::assert::is_false(tkr_parses("exit 42\n"))
    teko::assert::is_false(tkr_parses("kind = \"bogus\"\n"))
    teko::assert::is_false(tkr_parses("args = 42\n"))
    teko::assert::is_true(tkr_parses("exit = 1\n"))
}
