SampleClass() invariant;
let SampleClass() variant;

variant = invariant; // OK
invariant = variant; // compilation failure

var autoInvariant = SampleClass();
let autoVariant = autoInvariant;

ref var refInvariant = autoInvariant;
ref let refVariant = autoVariant;

refVariant.SayHello("there");
refVariant.PrintType<string>();
