type is abstract and implements SampleInterface;

abstract void SayHello(string);

void PrintType<T>()
{
    var name = nameof(T);
    printf `The name of type is {name}`;

    if (HAS_INTERNET_ACCESS) {
        printf ` from google!\n`;
        return;
    }

    printf '!\n';
}

virtual void PrintContent<T>(T value)
{
    printf `The content is: '{value.Content}'\n`
}
