type is transient and extends SampleAbstractClass with SampleTrait;

string Content;

init {
    Content = "World";
}

void SayHello(string value)
{
    var content = this.GetHello(value);

    printf `{content}!\n`;
    PrintContent(this);
}

override void PrintContent<T>(T value)
{
    base.PrintContent(value);
}
