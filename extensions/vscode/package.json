{
  "name": "teko",
  "displayName": "Teko Language Support",
  "description": "Suporte oficial e Tooling para a linguagem de programação Teko",
  "version": "0.0.1",
  "publisher": "schivei",
  "repository": {
    "type": "git",
    "url": "https://github.com"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Debuggers"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onLanguage:teko"
  ],
  "contributes": {
    "languages": [
      {
        "id": "teko",
        "aliases": [
          "Teko",
          "teko"
        ],
        "extensions": [
          ".tks",
          ".tkp"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "teko",
        "scopeName": "source.tks",
        "path": "./syntaxes/teko.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "teko.run",
        "title": "Teko: Executar Projeto (Run)",
        "category": "Teko"
      },
      {
        "command": "teko.build",
        "title": "Teko: Compilar Projeto (Build)",
        "category": "Teko"
      }
    ],
    "configuration": {
      "title": "Teko",
      "properties": {
        "teko.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Caminho absoluto para o executável do compilador Teko (Deixe vazio para usar o 'teko' global do PATH)."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0",
    "minimatch": "^10.2.5",
    "glob": "13.0.6"
  },
  "devDependencies": {
    "vscode": "^1.1.37"
  }
}
