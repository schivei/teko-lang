{
  "$schema": "https://githubusercontent.com",
  "name": "Teko",
  "scopeName": "source.tks",
  "patterns": [
    {
      "name": "keyword.control.teko",
      "match": "\\b(use|from|extern|defer|return|when|for|switch|raised|where|with)\\b"
    },
    {
      "name": "keyword.declaration.teko",
      "match": "\\b(struct|fn|const|async|let|mut|exp|interface|service|decorates|extend|command|handler|notification|query|pub)\\b"
    },
    {
      "name": "storage.type.teko",
      "match": "\\b(i32|u8|str|ptr|void|decimal|bigint|arena|fs|intent)\\b"
    },
    {
      "name": "keyword.operator.elvis.teko",
      "match": "\\?\\?"
    },
    {
      "name": "keyword.operator.safe-navigation.teko",
      "match": "\\?\\."
    },
    {
      "name": "constant.language.teko",
      "match": "\\bnull\\b"
    }
  ]
}