// Registra um bloco de atraso assíncrono suspendendo a Green Thread atual (Non-blocking sleep)
pub fn sleep_ms(duration: i32) : intent<void>;

// Força a Green Thread atual a ceder seu tempo de CPU voluntariamente (Yielding)
pub fn yield_now() : void;