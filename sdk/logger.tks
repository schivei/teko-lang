// ============================================================================
// Teko SDK - Mecanismo de Logs e Saída Padrão de Sistema
// Namespace Interno: teko::logger
// ============================================================================

// Imprime uma string diretamente no console (stdout)
pub fn info(message: str) : void;

// Imprime uma mensagem de erro na saída de diagnósticos (stderr)
pub fn error(message: str) : void;
